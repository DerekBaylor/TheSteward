@namespace TheSteward.Shared.Components.DashboardComponets

<div class="container mt-4">
    <h2>Your Household Dashboard</h2>
    <div class="row g-4 mt-3">
        <div class="col-12 col-lg-6">
            <DashboardCalendar />
        </div>
        <div class="col-12 col-lg-6">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h4 class="card-title">Today's Overview</h4>
                    <p class="text-muted">Your tasks, appointments, and meals for today will appear here.</p>
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item">• Task placeholder</li>
                        <li class="list-group-item">• Appointment placeholder</li>
                        <li class="list-group-item">• Meal placeholder</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

