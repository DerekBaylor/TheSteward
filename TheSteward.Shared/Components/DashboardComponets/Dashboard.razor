@namespace TheSteward.Shared.Components.DashboardComponets

<div class="dashboard-container">
    <div class="dashboard-header">
        <h2 class="dashboard-title">Your Household Dashboard</h2>
        <p class="dashboard-subtitle">@GetGreeting()</p>
    </div>

    <div class="dashboard-grid">
        <!-- Calendar Section -->
        <div class="dashboard-section calendar-section">
            <DashboardCalendar />
        </div>

        <!-- Today's Overview Section -->
        <div class="dashboard-section overview-section">
            <div class="section-card">
                <div class="section-header">
                    <h3 class="section-title">Today's Overview</h3>
                    <span class="section-date">@DateTime.Today.ToString("MMM dd, yyyy")</span>
                </div>

                <div class="overview-content">
                    <!-- Tasks -->
                    <div class="overview-category">
                        <div class="category-header">
                            <div class="category-icon tasks-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M9 11l3 3L22 4"></path>
                                    <path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"></path>
                                </svg>
                            </div>
                            <h4 class="category-title">Tasks</h4>
                            <span class="category-badge">3</span>
                        </div>
                        <ul class="category-list">
                            <li class="category-item">
                                <span class="item-bullet"></span>
                                <span class="item-text">Complete weekly grocery shopping</span>
                            </li>
                            <li class="category-item">
                                <span class="item-bullet"></span>
                                <span class="item-text">Review household budget</span>
                            </li>
                            <li class="category-item">
                                <span class="item-bullet"></span>
                                <span class="item-text">Schedule maintenance appointment</span>
                            </li>
                        </ul>
                    </div>

                    <!-- Appointments -->
                    <div class="overview-category">
                        <div class="category-header">
                            <div class="category-icon appointments-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <circle cx="12" cy="12" r="10"></circle>
                                    <polyline points="12 6 12 12 16 14"></polyline>
                                </svg>
                            </div>
                            <h4 class="category-title">Appointments</h4>
                            <span class="category-badge">2</span>
                        </div>
                        <ul class="category-list">
                            <li class="category-item">
                                <span class="item-time">10:00 AM</span>
                                <span class="item-text">Doctor's appointment</span>
                            </li>
                            <li class="category-item">
                                <span class="item-time">3:30 PM</span>
                                <span class="item-text">Parent-teacher conference</span>
                            </li>
                        </ul>
                    </div>

                    <!-- Meals -->
                    <div class="overview-category">
                        <div class="category-header">
                            <div class="category-icon meals-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 002-2V2"></path>
                                    <path d="M7 2v20"></path>
                                    <path d="M21 15V2v0a5 5 0 00-5 5v6c0 1.1.9 2 2 2h3zm0 0v7"></path>
                                </svg>
                            </div>
                            <h4 class="category-title">Meals</h4>
                            <span class="category-badge">3</span>
                        </div>
                        <ul class="category-list">
                            <li class="category-item">
                                <span class="item-label">Breakfast</span>
                                <span class="item-text">Oatmeal with berries</span>
                            </li>
                            <li class="category-item">
                                <span class="item-label">Lunch</span>
                                <span class="item-text">Chicken Caesar salad</span>
                            </li>
                            <li class="category-item">
                                <span class="item-label">Dinner</span>
                                <span class="item-text">Spaghetti Bolognese</span>
                            </li>
                        </ul>
                    </div>
                </div>

                <div class="section-footer">
                    <button class="btn-view-all">
                        View All Activities
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="9 18 15 12 9 6"></polyline>
                        </svg>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string GetGreeting()
    {
        var hour = DateTime.Now.Hour;
        if (hour < 12)
            return "Good morning! Here's what's happening today.";
        else if (hour < 17)
            return "Good afternoon! Here's what's happening today.";
        else
            return "Good evening! Here's what's happening today.";
    }
}