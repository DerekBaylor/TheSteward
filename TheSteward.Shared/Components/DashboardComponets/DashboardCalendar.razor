@namespace TheSteward.Shared.Components.DashboardComponets

@using TheSteward.Shared.Dtos.DashboardDtos

<div class="calendar-card">

    @* ── Month Navigation ── *@
    <div class="calendar-header">
        <button class="calendar-nav-btn" @onclick="GoToPreviousMonth">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="15 18 9 12 15 6"></polyline>
            </svg>
        </button>
        <h3 class="calendar-month">@visibleMonth.ToString("MMMM yyyy")</h3>
        <button class="calendar-nav-btn" @onclick="GoToNextMonth">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
        </button>
    </div>

    @* ── Day-of-week headers ── *@
    <div class="calendar-grid">
        @foreach (var day in new[] { "Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat" })
        {
            <div class="calendar-day-header">@day</div>
        }

        @* ── Day cells ── *@
        @foreach (var cell in calendarCells)
        {
            <div class="calendar-day @GetCellCss(cell)" @onclick="() => SelectDate(cell)">
                <span class="day-number">@cell.Day</span>
                @if (OccurrenceDates.Contains(cell.Date))
                {
                    <span class="event-indicator"></span>
                }
            </div>
        }
    </div>

</div>

@code {

    // ── Parameters ─────────────────────────────────────────────────────────
    [Parameter] public HashSet<DateTime> OccurrenceDates { get; set; } = new();
    [Parameter] public DateTime SelectedDate { get; set; } = DateTime.Today;
    [Parameter] public EventCallback<DateTime> SelectedDateChanged { get; set; }
    [Parameter] public EventCallback<DateTime> OnMonthChanged { get; set; }

    // ── Private state ──────────────────────────────────────────────────────
    private DateTime visibleMonth;
    private List<DateTime> calendarCells = new();

    // ── Lifecycle ──────────────────────────────────────────────────────────
    protected override void OnInitialized()
    {
        visibleMonth = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
        BuildCalendarCells();
    }

    // ── Navigation ─────────────────────────────────────────────────────────
    private async Task GoToPreviousMonth()
    {
        visibleMonth = visibleMonth.AddMonths(-1);
        BuildCalendarCells();
        await OnMonthChanged.InvokeAsync(visibleMonth);
    }

    private async Task GoToNextMonth()
    {
        visibleMonth = visibleMonth.AddMonths(1);
        BuildCalendarCells();
        await OnMonthChanged.InvokeAsync(visibleMonth);
    }

    // ── Day selection ──────────────────────────────────────────────────────
    private async Task SelectDate(DateTime date)
    {
        await SelectedDateChanged.InvokeAsync(date);
    }

    // ── Calendar cell builder ──────────────────────────────────────────────
    private void BuildCalendarCells()
    {
        calendarCells.Clear();

        var firstDay = visibleMonth;
        var startOffset = (int)firstDay.DayOfWeek; // 0 = Sunday
        var daysInMonth = DateTime.DaysInMonth(firstDay.Year, firstDay.Month);

        // Leading days from the previous month
        for (int i = startOffset - 1; i >= 0; i--)
            calendarCells.Add(firstDay.AddDays(-i - 1));

        // Current month days
        for (int d = 1; d <= daysInMonth; d++)
            calendarCells.Add(new DateTime(firstDay.Year, firstDay.Month, d));

        // Trailing days to complete the last row
        int trailing = 7 - (calendarCells.Count % 7);
        if (trailing < 7)
            for (int i = 1; i <= trailing; i++)
                calendarCells.Add(firstDay.AddMonths(1).AddDays(i - 1));
    }

    // ── CSS helpers — maps to your existing CSS class names ────────────────
    private string GetCellCss(DateTime date)
    {
        var classes = new System.Text.StringBuilder();

        if (date.Month != visibleMonth.Month)
            classes.Append(" other-month");

        if (date.Date == DateTime.Today)
            classes.Append(" today");

        if (date.Date == SelectedDate.Date)
            classes.Append(" selected");

        return classes.ToString().Trim();
    }
}


