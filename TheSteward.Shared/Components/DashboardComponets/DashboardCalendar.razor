@namespace TheSteward.Shared.Components.DashboardComponets

<div class="calendar-card">
    <div class="calendar-header">
        <button class="calendar-nav-btn" @onclick="PreviousMonth">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="15 18 9 12 15 6"></polyline>
            </svg>
        </button>

        <h3 class="calendar-month">@currentDate.ToString("MMMM yyyy")</h3>

        <button class="calendar-nav-btn" @onclick="NextMonth">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
        </button>
    </div>

    <div class="calendar-grid">
        <div class="calendar-day-header">Sun</div>
        <div class="calendar-day-header">Mon</div>
        <div class="calendar-day-header">Tue</div>
        <div class="calendar-day-header">Wed</div>
        <div class="calendar-day-header">Thu</div>
        <div class="calendar-day-header">Fri</div>
        <div class="calendar-day-header">Sat</div>

        @foreach (var day in calendarDays)
        {
            <div class="@GetDayClass(day)" @onclick="() => SelectDay(day)">
                <span class="day-number">@day.Day</span>
                @if (day.HasEvent)
                {
                    <div class="event-indicator"></div>
                }
            </div>
        }
    </div>
</div>

@code {
    // ── Parameters ─────────────────────────────────────────────────────────
    /// <summary>
    /// Set of local dates that have at least one task due.
    /// Passed in from Dashboard so the calendar reflects real data.
    /// </summary>
    [Parameter]
    public HashSet<DateTime> TaskDates { get; set; } = new();

    // ── State ──────────────────────────────────────────────────────────────
    private DateTime currentDate = DateTime.Today;
    private List<CalendarDay> calendarDays = new();
    private CalendarDay? selectedDay;

    // ── Lifecycle ──────────────────────────────────────────────────────────
    protected override void OnInitialized() => GenerateCalendar();

    // Re-generate whenever TaskDates changes so new data is reflected
    protected override void OnParametersSet() => GenerateCalendar();

    // ── Calendar Generation ────────────────────────────────────────────────
    private void GenerateCalendar()
    {
        calendarDays.Clear();

        var firstDayOfMonth = new DateTime(currentDate.Year, currentDate.Month, 1);
        var lastDayOfMonth = firstDayOfMonth.AddMonths(1).AddDays(-1);
        int startDayOfWeek = (int)firstDayOfMonth.DayOfWeek;

        // Trailing days from the previous month
        var previousMonth = firstDayOfMonth.AddMonths(-1);
        var daysInPreviousMonth = DateTime.DaysInMonth(previousMonth.Year, previousMonth.Month);

        for (int i = startDayOfWeek - 1; i >= 0; i--)
        {
            calendarDays.Add(new CalendarDay
            {
                Date = new DateTime(previousMonth.Year, previousMonth.Month, daysInPreviousMonth - i),
                IsCurrentMonth = false,
                HasEvent = false   // don't show indicators for overflow days
            });
        }

        // Days in the current month
        for (int day = 1; day <= lastDayOfMonth.Day; day++)
        {
            var date = new DateTime(currentDate.Year, currentDate.Month, day);
            calendarDays.Add(new CalendarDay
            {
                Date = date,
                IsCurrentMonth = true,
                HasEvent = TaskDates.Contains(date)   // ← real data
            });
        }

        // Leading days from the next month to fill the grid to 42 cells
        int remainingDays = 42 - calendarDays.Count;
        var nextMonth = firstDayOfMonth.AddMonths(1);

        for (int day = 1; day <= remainingDays; day++)
        {
            calendarDays.Add(new CalendarDay
            {
                Date = new DateTime(nextMonth.Year, nextMonth.Month, day),
                IsCurrentMonth = false,
                HasEvent = false
            });
        }
    }

    // ── Helpers ────────────────────────────────────────────────────────────
    private string GetDayClass(CalendarDay day)
    {
        var classes = new List<string> { "calendar-day" };

        if (!day.IsCurrentMonth) classes.Add("other-month");
        if (day.Date == DateTime.Today) classes.Add("today");
        if (selectedDay?.Date == day.Date) classes.Add("selected");

        return string.Join(" ", classes);
    }

    private void SelectDay(CalendarDay day) => selectedDay = day;

    private void PreviousMonth()
    {
        currentDate = currentDate.AddMonths(-1);
        GenerateCalendar();
    }

    private void NextMonth()
    {
        currentDate = currentDate.AddMonths(1);
        GenerateCalendar();
    }

    // ── Inner Types ────────────────────────────────────────────────────────
    private class CalendarDay
    {
        public DateTime Date { get; set; }
        public bool IsCurrentMonth { get; set; }
        public bool HasEvent { get; set; }
        public int Day => Date.Day;
    }
}


