@namespace TheSteward.Shared.Components.DashboardComponets

<MudPaper Elevation="2" Class="pa-4">
    <MudStack Spacing="3">
        <MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft"
                           Size="Size.Small"
                           OnClick="PreviousMonth" />

            <MudText Typo="Typo.h6" Class="flex-grow-1 text-center">
                @currentDate.ToString("MMMM yyyy")
            </MudText>

            <MudIconButton Icon="@Icons.Material.Filled.ChevronRight"
                           Size="Size.Small"
                           OnClick="NextMonth" />
        </MudStack>

        <div class="calendar-grid">
            <div class="calendar-day-header">Sun</div>
            <div class="calendar-day-header">Mon</div>
            <div class="calendar-day-header">Tue</div>
            <div class="calendar-day-header">Wed</div>
            <div class="calendar-day-header">Thu</div>
            <div class="calendar-day-header">Fri</div>
            <div class="calendar-day-header">Sat</div>

            @foreach (var day in calendarDays)
            {
                <MudPaper Elevation="0"
                          Class="@GetDayClass(day)"
                          Style="@GetDayStyle(day)">
                    <MudText Typo="Typo.body2">@day.Day</MudText>
                    @if (day.HasEvent)
                    {
                        <div class="event-indicator"></div>
                    }
                </MudPaper>
            }
        </div>
    </MudStack>
</MudPaper>

<style>
    .calendar-grid {
        display: grid;
        grid-template-columns: repeat(7, 1fr);
        gap: 8px;
    }

    .calendar-day-header {
        text-align: center;
        font-weight: 600;
        font-size: 0.875rem;
        color: var(--mud-palette-text-secondary);
        padding: 8px 0;
        border-bottom: 2px solid var(--mud-palette-divider);
    }

    .calendar-day {
        aspect-ratio: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 8px;
        border-radius: var(--mud-default-borderradius);
        position: relative;
        cursor: pointer;
        transition: all 0.2s ease;
    }

        .calendar-day:hover {
            transform: scale(1.05);
        }

        .calendar-day.other-month {
            opacity: 0.3;
        }

    .event-indicator {
        width: 6px;
        height: 6px;
        background: var(--mud-palette-success);
        border-radius: 50%;
        position: absolute;
        bottom: 4px;
    }

    .calendar-day.today .event-indicator {
        background: white;
    }

    @@media (max-width: 768px) {
        .calendar-grid {
            gap: 4px;
        }

        .calendar-day {
            padding: 4px;
        }

        .calendar-day-header {
            font-size: 0.75rem;
            padding: 4px 0;
        }
    }
</style>

@code {
    private DateTime currentDate = DateTime.Today;
    private List<CalendarDay> calendarDays = new();

    protected override void OnInitialized()
    {
        GenerateCalendar();
    }

    private void GenerateCalendar()
    {
        calendarDays.Clear();

        var firstDayOfMonth = new DateTime(currentDate.Year, currentDate.Month, 1);
        var lastDayOfMonth = firstDayOfMonth.AddMonths(1).AddDays(-1);

        // Get the starting day (Sunday = 0)
        int startDayOfWeek = (int)firstDayOfMonth.DayOfWeek;

        // Add previous month days
        var previousMonth = firstDayOfMonth.AddMonths(-1);
        var daysInPreviousMonth = DateTime.DaysInMonth(previousMonth.Year, previousMonth.Month);

        for (int i = startDayOfWeek - 1; i >= 0; i--)
        {
            calendarDays.Add(new CalendarDay
            {
                Date = new DateTime(previousMonth.Year, previousMonth.Month, daysInPreviousMonth - i),
                IsCurrentMonth = false,
                HasEvent = false
            });
        }

        // Add current month days
        for (int day = 1; day <= lastDayOfMonth.Day; day++)
        {
            var date = new DateTime(currentDate.Year, currentDate.Month, day);
            calendarDays.Add(new CalendarDay
            {
                Date = date,
                IsCurrentMonth = true,
                HasEvent = Random.Shared.Next(0, 5) == 0 // Random events for demo
            });
        }

        // Add next month days to fill the grid
        int remainingDays = 42 - calendarDays.Count; // 6 rows x 7 days
        var nextMonth = firstDayOfMonth.AddMonths(1);

        for (int day = 1; day <= remainingDays; day++)
        {
            calendarDays.Add(new CalendarDay
            {
                Date = new DateTime(nextMonth.Year, nextMonth.Month, day),
                IsCurrentMonth = false,
                HasEvent = false
            });
        }
    }

    private string GetDayClass(CalendarDay day)
    {
        var classes = new List<string> { "calendar-day" };

        if (!day.IsCurrentMonth)
            classes.Add("other-month");

        if (day.Date.Date == DateTime.Today)
            classes.Add("today");

        return string.Join(" ", classes);
    }

    private string GetDayStyle(CalendarDay day)
    {
        if (day.Date.Date == DateTime.Today)
        {
            return "background: var(--mud-palette-primary); color: white; font-weight: bold;";
        }

        return "background: var(--mud-palette-surface);";
    }

    private void PreviousMonth()
    {
        currentDate = currentDate.AddMonths(-1);
        GenerateCalendar();
    }

    private void NextMonth()
    {
        currentDate = currentDate.AddMonths(1);
        GenerateCalendar();
    }

    private class CalendarDay
    {
        public DateTime Date { get; set; }
        public bool IsCurrentMonth { get; set; }
        public bool HasEvent { get; set; }
        public int Day => Date.Day;
    }
}