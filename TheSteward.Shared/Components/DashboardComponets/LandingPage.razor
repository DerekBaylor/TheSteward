@inject NavigationManager NavigationManager
@namespace TheSteward.Shared.Components.DashboardComponets

<div class="landing-container">
    <div class="landing-content">
        <!-- Hero Section -->
        <div class="hero-section">
            <h1 class="hero-title">Welcome to The Steward</h1>
            <p class="hero-subtitle">Your complete household management companion</p>
            <p class="hero-description">
                Take control of your home management with tasks, calendars, and meal planning—all in one place.
            </p>

            <div class="hero-buttons">
                <button class="btn-hero-primary" @onclick="GoToLogin">
                    Sign In
                </button>
                <button class="btn-hero-secondary" @onclick="GoToRegister">
                    Create Account
                </button>
            </div>
        </div>

        <!-- Features Section -->
        <div class="features-grid">
            <div class="feature-card">
                <div class="feature-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M9 11l3 3L22 4"></path>
                        <path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"></path>
                    </svg>
                </div>
                <h3 class="feature-title">Task Management</h3>
                <p class="feature-description">
                    Keep track of household tasks and assign them to family members with ease.
                </p>
            </div>

            <div class="feature-card">
                <div class="feature-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                        <line x1="16" y1="2" x2="16" y2="6"></line>
                        <line x1="8" y1="2" x2="8" y2="6"></line>
                        <line x1="3" y1="10" x2="21" y2="10"></line>
                    </svg>
                </div>
                <h3 class="feature-title">Shared Calendar</h3>
                <p class="feature-description">
                    Coordinate schedules and never miss important family events again.
                </p>
            </div>

            <div class="feature-card">
                <div class="feature-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"></path>
                        <polyline points="9 22 9 12 15 12 15 22"></polyline>
                    </svg>
                </div>
                <h3 class="feature-title">Household Hub</h3>
                <p class="feature-description">
                    Centralize all your household information in one convenient location.
                </p>
            </div>

            <div class="feature-card">
                <div class="feature-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"></path>
                        <circle cx="9" cy="7" r="4"></circle>
                        <path d="M23 21v-2a4 4 0 00-3-3.87"></path>
                        <path d="M16 3.13a4 4 0 010 7.75"></path>
                    </svg>
                </div>
                <h3 class="feature-title">Family Collaboration</h3>
                <p class="feature-description">
                    Work together with household members to keep everything running smoothly.
                </p>
            </div>
        </div>
    </div>
</div>

@code {
    private void GoToLogin() => NavigationManager.NavigateTo("Account/Login", forceLoad: true);
    private void GoToRegister() => NavigationManager.NavigateTo("Account/Register", forceLoad: true);
}