@namespace TheSteward.Shared.Components.FinanceComponents

@using TheSteward.Core.Dtos.FinanceManagerDtos

<MudCard id="incomeCard" class="ts-tabbed-card" Elevation="0">

        <MudCardActions class="ts-tabbed-card-btn-container">
    @if (!IsReadOnly)
    {
            <MudButton id="addIncomeBtn"
                       class="ts-card-tab-btn"
                       StartIcon="@Icons.Material.Filled.Add"
                       OnClick="HandleAddIncome">
                Add Income
            </MudButton>
    }
            <MudButton id="showIncomeDetails"
                       class="ts-card-tab-btn"
                       StartIcon="@Icons.Material.Filled.FileOpen"
                       OnClick="HandleShowIncomeDetails"
                       Disabled="!Incomes.Any()">
                Income Details
            </MudButton>
        </MudCardActions>

    <MudCardContent class="ts-card-content">

        <MudCardHeader Class="ts-tabbed-card-header">
            <CardHeaderContent>
                <h3 class="ts-tabbed-card-title">
                    <span class="ts-label">Income</span>
                </h3>
            </CardHeaderContent>
        </MudCardHeader>

        <div class="ts-card-body">
            @if (!Incomes.Any())
            {
                <div class="income-empty-state">
                    <span class="material-icons income-empty-icon">account_balance_wallet</span>
                    <p class="income-empty-text">No income sources added yet.</p>
                </div>
            }
            else
            {
                <section class="ts-card-section">
                    <table class="income-table">
                        <thead>
                            <tr>
                                <th class="income-th income-th-name">Name</th>
                                <th class="income-th income-th-amount">Monthly Net</th>
                                <th class="income-th income-th-amount">Yearly Net</th>
                                @if (!IsReadOnly)
                                {
                                    <th class="income-th income-th-action"></th>
                                    <th class="income-th income-th-action"></th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var income in Incomes)
                            {
                                <tr class="income-row">
                                    <td class="income-td income-td-name">@income.IncomeName</td>
                                    <td class="income-td income-td-amount">@income.MonthlyNetIncome.ToString("C")</td>
                                    <td class="income-td income-td-amount">@((income.MonthlyNetIncome * 12).ToString("C"))</td>
                                    @if (!IsReadOnly)
                                    {
                                        <td class="income-td income-td-action">
                                            <button class="income-row-btn income-row-btn--edit"
                                                    title="Edit"
                                                    @onclick="() => HandleRowEdit(income)">
                                                <span class="material-icons">edit</span>
                                            </button>
                                        </td>
                                        <td class="income-td income-td-action">
                                            <button class="income-row-btn income-row-btn--delete"
                                                    title="Delete"
                                                    @onclick="() => HandleRowDelete(income)">
                                                <span class="material-icons">delete</span>
                                            </button>
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr class="income-totals-row">
                                <td class="income-td income-td-name income-totals-label">Total</td>
                                <td class="income-td income-td-amount income-totals-value">
                                    @Incomes.Sum(i => i.MonthlyNetIncome).ToString("C")
                                </td>
                                <td class="income-td income-td-amount income-totals-value">
                                    @Incomes.Sum(i => i.MonthlyNetIncome * 12).ToString("C")
                                </td>
                                @if (!IsReadOnly)
                                {
                                    <td class="income-td income-td-action"></td>
                                    <td class="income-td income-td-action"></td>
                                }
                            </tr>
                        </tfoot>
                    </table>
                </section>
            }
        </div>

    </MudCardContent>
</MudCard>

@code {
    [Parameter, EditorRequired]
    public List<IncomeDto> Incomes { get; set; } = new();

    /// <summary>Hides action buttons when the user only has read access.</summary>
    [Parameter]
    public bool IsReadOnly { get; set; } = false;

    [Parameter]
    public EventCallback OnAddIncome { get; set; }

    [Parameter]
    public EventCallback OnOpenIncomeDetails { get; set; }

    /// <summary>Passes the currently selected income back so the parent can open an edit form.</summary>
    [Parameter]
    public EventCallback<IncomeDto> OnEditIncome { get; set; }

    [Parameter]
    public EventCallback<IncomeDto> OnDeleteIncome { get; set; }

    private async Task HandleAddIncome()
    {
        await OnAddIncome.InvokeAsync();
    }

    private async Task HandleShowIncomeDetails()
    {
        //TODO: Add Detialed View of all Incomes
        await OnOpenIncomeDetails.InvokeAsync();
    }

    private async Task HandleRowEdit(IncomeDto income)
    {
        await OnEditIncome.InvokeAsync(income);
    }

    private async Task HandleRowDelete(IncomeDto income)
    {
        await OnDeleteIncome.InvokeAsync(income);
    }
}
