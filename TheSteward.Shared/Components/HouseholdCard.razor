@namespace TheSteward.Shared.Components

@using TheSteward.Core.Dtos.HouseholdDtos
@using TheSteward.Core.Models
@using System.Reflection
@using TheSteward.Core.Attributes

<div class="ts-card household-card">
    <div class="card-body">
        <p class="card-text">
            <strong>Status:</strong> @(HouseholdDto.IsHouseholdActive ? "Active" : "Inactive")
        </p>

        <h6 class="mt-3"><strong>Enabled Features:</strong></h6>

        <ul style="list-style: none; padding-left: 0;">
            @foreach (var feature in GetFeatures())
            {
                <li>
                    <span class="material-icons" style="@(feature.IsEnabled ? "color: green;" : "color: gray;") vertical-align: middle; font-size: 20px;">
                        @(feature.IsEnabled ? "check_circle" : "radio_button_unchecked")
                    </span>
                    <span style="@(feature.IsEnabled ? "" : "opacity: 0.6;")">@feature.Name</span>
                </li>
            }
        </ul>

        @* <button class="btn btn-secondary mt-3" @onclick="HandleEdit">Edit Household</button> *@
        <button class="ts-btn ts-edit-btn" @onclick="HandleEdit">Edit Household</button>

        <h6 class="mt-4"><strong>Members:</strong></h6>
        @if (HouseholdDto.Members != null && HouseholdDto.Members.Any())
        {
            <ul style="list-style: none; padding-left: 0;">
                @foreach (var member in HouseholdDto.Members)
                {
                    <li class="mb-2">
                        @if (HasAdminPermissions)
                        {
                            <button class="btn btn-link p-0 text-start" @onclick="() => HandleMemberClick(member)">
                                <span class="material-icons" style="vertical-align: middle; font-size: 20px;">person</span>
                                @member.UserName
                                @if (member.Id == HouseholdDto.OwnerId)
                                {
                                    <span class="badge bg-primary ms-2 owner-badge">Owner</span>
                                }
                            </button>
                        }
                        else
                        {
                            <span>
                                <span class="material-icons" style="vertical-align: middle; font-size: 20px;">person</span>
                                @member.UserName
                                @if (member.Id == HouseholdDto.OwnerId)
                                {
                                    <span class="badge bg-primary ms-2">Owner</span>
                                }
                            </span>
                        }
                    </li>
                }
            </ul>
        }
        else
        {
            <p class="text-muted">No members found.</p>
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public HouseholdDto HouseholdDto { get; set; } = null!;

    [Parameter, EditorRequired]
    public bool HasAdminPermissions { get; set; }

    [Parameter]
    public EventCallback OnEditHosuehold { get; set; }

    [Parameter]
    public EventCallback<ApplicationUser> GetMember { get; set; }

    private List<(string Name, bool IsEnabled)> GetFeatures()
    {
        var features = new List<(string Name, bool IsEnabled)>();

        var properties = typeof(HouseholdDto).GetProperties()
            .Where(p => p.GetCustomAttribute<HouseholdFeatureAttribute>() != null);

        foreach (var property in properties)
        {
            var attribute = property.GetCustomAttribute<HouseholdFeatureAttribute>();
            var value = (bool)(property.GetValue(HouseholdDto) ?? false);

            features.Add((attribute!.DisplayName, value));
        }

        return features;
    }

    private async Task HandleEdit()
    {
        await OnEditHosuehold.InvokeAsync();
    }

    private async Task HandleMemberClick(ApplicationUser member)
    {
        await GetMember.InvokeAsync(member);
    }
}