@namespace TheSteward.Shared.Components

@using TheSteward.Core.Dtos.HouseholdDtos
@using TheSteward.Core.Models


<h3>My Household</h3>
<div class="card">
    <div class="card-body">
        <h5 class="card-title">@HouseholdDto.HouseholdName</h5>
        <p class="card-text">
            <strong>Status:</strong> @(HouseholdDto.IsHouseholdActive ? "Active" : "Inactive")
        </p>

        <h6 class="mt-3">Enabled Features:</h6>
        <ul style="list-style: none; padding-left: 0;">
            <li>
                <span class="material-icons" style="@(HouseholdDto.HasTaskManagerAccess ? "color: green;" : "color: gray;") vertical-align: middle; font-size: 20px;">
                    @(HouseholdDto.HasTaskManagerAccess ? "check_circle" : "radio_button_unchecked")
                </span>
                <span style="@(HouseholdDto.HasTaskManagerAccess ? "" : "opacity: 0.6;")">Task Manager</span>
            </li>
            <li>
                <span class="material-icons" style="@(HouseholdDto.HasFinanceManagerAccess ? "color: green;" : "color: gray;") vertical-align: middle; font-size: 20px;">
                    @(HouseholdDto.HasFinanceManagerAccess ? "check_circle" : "radio_button_unchecked")
                </span>
                <span style="@(HouseholdDto.HasFinanceManagerAccess ? "" : "opacity: 0.6;")">Finance Manager</span>
            </li>
            <li>
                <span class="material-icons" style="@(HouseholdDto.HasMealManagerAccess ? "color: green;" : "color: gray;") vertical-align: middle; font-size: 20px;">
                    @(HouseholdDto.HasMealManagerAccess ? "check_circle" : "radio_button_unchecked")
                </span>
                <span style="@(HouseholdDto.HasMealManagerAccess ? "" : "opacity: 0.6;")">Meal Manager</span>
            </li>
            <li>
                <span class="material-icons" style="@(HouseholdDto.HasFileManagerAccess ? "color: green;" : "color: gray;") vertical-align: middle; font-size: 20px;">
                    @(HouseholdDto.HasFileManagerAccess ? "check_circle" : "radio_button_unchecked")
                </span>
                <span style="@(HouseholdDto.HasFileManagerAccess ? "" : "opacity: 0.6;")">File Manager</span>
            </li>
        </ul>

        <h6 class="mt-4">Members:</h6>
        @if (HouseholdDto.Members != null && HouseholdDto.Members.Any())
        {
            <ul style="list-style: none; padding-left: 0;">
                @foreach (var member in HouseholdDto.Members)
                {
                    <li class="mb-2">
                        @if (HasAdminPermissions)
                        {
                            <button class="btn btn-link p-0 text-start" @onclick="() => HandleMemberClick(member)">
                                <span class="material-icons" style="vertical-align: middle; font-size: 20px;">person</span>
                                @member.UserName
                                @if (member.Id == HouseholdDto.OwnerId)
                                {
                                    <span class="badge bg-primary ms-2">Owner</span>
                                }
                            </button>
                        }
                        else
                        {
                            <span>
                                <span class="material-icons" style="vertical-align: middle; font-size: 20px;">person</span>
                                @member.UserName
                                @if (member.Id == HouseholdDto.OwnerId)
                                {
                                    <span class="badge bg-primary ms-2">Owner</span>
                                }
                            </span>
                        }
                    </li>
                }
            </ul>
        }
        else
        {
            <p class="text-muted">No members found.</p>
        }

        <button class="btn btn-secondary mt-3" @onclick="HandleEdit">Edit</button>
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public HouseholdDto HouseholdDto { get; set; } = null!;

    [Parameter, EditorRequired]
    public bool HasAdminPermissions { get; set; }

    [Parameter]
    public EventCallback OnEdit { get; set; }

    [Parameter]
    public EventCallback<ApplicationUser> OnMemberEdit { get; set; }

    private async Task HandleEdit()
    {
        await OnEdit.InvokeAsync();
    }

    private async Task HandleMemberClick(ApplicationUser member)
    {
        await OnMemberEdit.InvokeAsync(member);
    }
}