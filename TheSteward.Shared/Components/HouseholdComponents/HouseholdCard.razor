@namespace TheSteward.Shared.Components.HouseholdComponents

@using TheSteward.Core.Dtos.HouseholdDtos
@using TheSteward.Core.Models
@using System.Reflection
@using TheSteward.Core.Attributes

<MudCard id="householdCard" class="ts-tabbed-card" Elevation="0">
    @if (HasAdminPermissions)
    {
        <MudCardActions class="ts-tabbed-card-btn-container">
            <MudButton id="editHouseholdBtn" class="ts-card-tab-btn" @onclick="HandleEdit">Edit Household</MudButton>
            <MudButton id="addMemberBtn" class="ts-card-tab-btn" @onclick="HandleAddMember">Add Member</MudButton>
        </MudCardActions>
    }
    <MudCardContent class="ts-card-content">
        <MudCardHeader Class="ts-tabbed-card-header">
            <h3 class="ts-tabbed-card-title"><span class="ts-label"> @HouseholdDto.HouseholdName: </span></h3>
        </MudCardHeader>
        <div class="ts-card-body">
            <section class="ts-card-section">
                <p id="householdStatusRow" class="ts-card-row">
                    <span class="ts-row-title">Status:</span> @(HouseholdDto.IsHouseholdActive ? "Active" : "Inactive")
                </p>
            </section>
            <section class="ts-card-section">
                <p class="ts-label">Features:</p>
                <ul id="householdFeatureList" class="ts-card-list" >
                    @foreach (var feature in GetFeatures())
                    {
                        <li>
                            <span style="@(feature.IsEnabled ? "" : "opacity: 0.6;")">@feature.Name</span>
                            <span class="material-icons" style="@(feature.IsEnabled ? "color: green;" : "color: gray;") vertical-align: middle; font-size: 20px;">
                                @(feature.IsEnabled ? "check_circle" : "radio_button_unchecked")
                            </span>
                        </li>
                    }
                </ul>
            </section>
            <section class="ts-card-section">
                <p class="ts-label">Members:</p>
                @if (HouseholdDto.UserHouseholdDtos != null && HouseholdDto.UserHouseholdDtos.Any())
                {
                    <ul class="ts-card-list">
                        @foreach (var userHousehold in HouseholdDto.UserHouseholdDtos)
                        {
                            @if (userHousehold.User != null)
                            {
                                <li class="mb-2">
                                    @if (HasAdminPermissions)
                                    {
                                        <div class="member-list-row">
                                            <button class="member-list-btn" @onclick="() => HandleMemberClick(userHousehold.User)">
                                                <span class="material-icons">person</span>
                                                <span>@userHousehold.User.UserName</span>
                                                @if (userHousehold.HasAdminPermissions)
                                                {
                                                    <MudBadge Content="adminBadge" Color="Color.Primary" Overlap="false" Class="mx-6 my-4" />
                                                }
                                            </button>
                                            <button class="member-remove-btn"
                                                    title="Remove or deactivate member"
                                                    @onclick="() => HandleRemoveMemberClick(userHousehold.User)">
                                                <span class="material-icons">delete</span>
                                            </button>
                                        </div>
                                    }
                                    else
                                    {
                                        <span>
                                            <span class="material-icons">person</span>
                                            <span>@userHousehold.User.UserName</span>
                                            @if (userHousehold.HasAdminPermissions)
                                            {
                                                <MudBadge Content="adminBadge" Color="Color.Primary" Overlap="false" Class="mx-6 my-4" />
                                            }
                                        </span>
                                    }
                                </li>
                            }
                        }
                    </ul>
                }
                else
                {
                    <p class="text-muted">No members found.</p>
                }
            </section>
        </div>
    </MudCardContent>
</MudCard>

@code {
    [Parameter, EditorRequired]
    public HouseholdDto HouseholdDto { get; set; } = null!;

    [Parameter, EditorRequired]
    public bool HasAdminPermissions { get; set; }

    [Parameter]
    public EventCallback OnEditHosuehold { get; set; }

    [Parameter]
    public EventCallback OnAddMember { get; set; }

    [Parameter]
    public EventCallback<ApplicationUser> GetMember { get; set; }

    [Parameter]
    public EventCallback<ApplicationUser> OnRemoveMember { get; set; }

    private string adminBadge = "Admin";

    private List<(string Name, bool IsEnabled)> GetFeatures()
    {
        var features = new List<(string Name, bool IsEnabled)>();

        var properties = typeof(HouseholdDto).GetProperties()
            .Where(p => p.GetCustomAttribute<HouseholdFeatureAttribute>() != null);

        foreach (var property in properties)
        {
            var attribute = property.GetCustomAttribute<HouseholdFeatureAttribute>();
            var value = (bool)(property.GetValue(HouseholdDto) ?? false);

            features.Add((attribute!.DisplayName, value));
        }

        return features;
    }

    private async Task HandleEdit()
    {
        await OnEditHosuehold.InvokeAsync();
    }

    private async Task HandleAddMember()
    {
        await OnAddMember.InvokeAsync();
    }

    private async Task HandleMemberClick(ApplicationUser member)
    {
        await GetMember.InvokeAsync(member);
    }

    private async Task HandleRemoveMemberClick(ApplicationUser member)
    {
        await OnRemoveMember.InvokeAsync(member);
    }
}