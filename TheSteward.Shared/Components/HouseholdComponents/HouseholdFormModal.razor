@namespace TheSteward.Shared.Components.HouseholdComponents
@using TheSteward.Shared.Dtos.HouseholdDtos

<MudDialog id="householdFormModal" Class="household-form-modal ts-modal">
    <DialogContent>
        <MudElement Class="modal-layout">

            <MudStack Class="modal-sidebar">
                <MudElement Class="modal-sidebar-content">
                    <MudIcon Icon="@(IsEditMode ? Icons.Material.Filled.Edit : Icons.Material.Filled.Add)" />
                    <MudText Typo="Typo.h6">HOUSEHOLD</MudText>
                </MudElement>
            </MudStack>

            <MudStack Class="modal-right-stack">
                <EditForm Model="FormData" OnValidSubmit="HandleSubmit">
                    <DataAnnotationsValidator />

                    <MudTextField @bind-Value="FormData.HouseholdName"
                                  Label="Household Name"
                                  Variant="Variant.Outlined"
                                  For="@(() => FormData.HouseholdName)"
                                  Margin="Margin.Dense"
                                  Class="" />
                    <MudText Typo="Typo.subtitle2" Class="mb-2">Enable Modules:</MudText>

                    <MudSwitch @bind-Value="FormData.HasTaskManagerAccess"
                               Label="Enable Task Manager"
                               Color="Color.Primary"/>

                    <MudSwitch @bind-Value="FormData.HasFinanceManagerAccess"
                               Label="Enable Finance Manager"
                               Color="Color.Primary"/>

                    <MudSwitch @bind-Value="FormData.HasKitchenManagerAccess"
                               Label="Enable Kitchen Manager"
                               Color="Color.Primary"/>

                    <MudSwitch @bind-Value="FormData.HasFileManagerAccess"
                               Label="Enable File Manager"
                               Color="Color.Primary"/>
                </EditForm>

            <MudElement Class="modal-actions">
                <MudButton OnClick="HandleCancel"
                           Variant="Variant.Outlined">
                    Cancel
                </MudButton>
                <MudButton OnClick="HandleSubmit"
                           Variant="Variant.Filled"
                           Color="Color.Primary">
                    @(IsEditMode ? "Update" : "Create")
                </MudButton>
            </MudElement>
        </MudStack>

        </MudElement>
    </DialogContent>

</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter, EditorRequired]
    public HouseholdFormDto FormData { get; set; } = new();

    [Parameter]
    public bool IsEditMode { get; set; }

    [Parameter]
    public bool HasDefaultHousehold { get; set; }

    private void HandleSubmit()
    {
        MudDialog.Close(DialogResult.Ok(FormData));
    }

    private void HandleCancel()
    {
        MudDialog.Cancel();
    }
}