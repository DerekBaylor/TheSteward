@namespace TheSteward.Shared.Components.HouseholdComponents
@using TheSteward.Core.Dtos.HouseholdDtos

<MudDialog Class="ts-modal invite-member-modal ">
    <DialogContent>
        <MudElement Class="modal-layout">

            <MudStack class="modal-sidebar">
                <MudElement class="modal-sidebar-content">
                    <MudIcon Icon="@Icons.Material.Filled.Add" />
                    <MudText Typo="Typo.h6">INVITE</MudText>
                </MudElement>
            </MudStack>

            <MudStack Class="modal-right-stack">
                <EditForm Model="inviteDto" OnValidSubmit="HandleSubmit">
                    <DataAnnotationsValidator />

                    <MudTextField @bind-Value="inviteDto.Email"
                                  Label="Email Address"
                                  Variant="Variant.Outlined"
                                  For="@(() => inviteDto.Email)"
                                  Margin="Margin.Dense"
                                  Placeholder="user@example.com"
                                  InputType="InputType.Email"
                                  Class="mb-4" />

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <MudAlert Severity="Severity.Error" Class="mb-3">@errorMessage</MudAlert>
                    }

                    @if (!string.IsNullOrEmpty(successMessage))
                    {
                        <MudAlert Severity="Severity.Success" Class="mb-3">@successMessage</MudAlert>
                    }
                </EditForm>

                <MudElement Class="modal-actions">
                        <MudButton OnClick="HandleCancel"
                                   Variant="Variant.Outlined"
                                   Disabled="@isSubmitting">
                            Cancel
                        </MudButton>
                        <MudButton OnClick="HandleSubmit"
                                   Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Disabled="@isSubmitting">
                            @if (isSubmitting)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
                            }
                            Send Invitation
                        </MudButton>
                </MudElement>
            </MudStack>
        </MudElement>
    </DialogContent>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter, EditorRequired]
    public Guid HouseholdId { get; set; }

    private InviteUserToHouseholdDto inviteDto = new();
    private bool isSubmitting = false;
    private string? errorMessage;
    private string? successMessage;

    protected override void OnInitialized()
    {
        inviteDto.HouseholdId = HouseholdId;
    }

    private async Task HandleSubmit()
    {
        isSubmitting = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            // Close dialog with the invite data as result
            MudDialog.Close(DialogResult.Ok(inviteDto));
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            isSubmitting = false;
        }
    }

    private void HandleCancel()
    {
        MudDialog.Cancel();
    }
}