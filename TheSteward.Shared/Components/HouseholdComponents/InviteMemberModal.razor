@namespace TheSteward.Shared.Components.HouseholdComponents
@using TheSteward.Core.Dtos.HouseholdDtos

<MudDialog Class="invite-member-modal ts-modal">
    <TitleContent>
        <div class="modal-header-custom">
            <MudText Typo="Typo.h5">Invite Memeber to Household</MudText>
            <MudIconButton Icon="@Icons.Material.Filled.Close"
                           OnClick="HandleCancel"
                           Class="modal-close-btn" />
        </div>
    </TitleContent>

    <DialogContent>
        <EditForm Model="inviteDto" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />

            <MudTextField @bind-Value="inviteDto.Email"
                          Label="Email Address"
                          Variant="Variant.Outlined"
                          For="@(() => inviteDto.Email)"
                          Margin="Margin.Dense"
                          Placeholder="user@example.com"
                          InputType="InputType.Email"
                          Class="mb-4" />

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <MudAlert Severity="Severity.Error" Class="mb-3">@errorMessage</MudAlert>
            }

            @if (!string.IsNullOrEmpty(successMessage))
            {
                <MudAlert Severity="Severity.Success" Class="mb-3">@successMessage</MudAlert>
            }
        </EditForm>
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="HandleCancel"
                   Variant="Variant.Outlined"
                   Color="Color.Default"
                   Disabled="@isSubmitting"
                   Class="ts-btn ts-cancel-btn">
            Cancel
        </MudButton>
        <MudButton OnClick="HandleSubmit"
                   Variant="Variant.Filled"
                   Disabled="@isSubmitting"
                   Class="ts-btn card-btn send-btn">
            @if (isSubmitting)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
            }
            Send Invitation
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter, EditorRequired]
    public Guid HouseholdId { get; set; }

    private InviteUserToHouseholdDto inviteDto = new();
    private bool isSubmitting = false;
    private string? errorMessage;
    private string? successMessage;

    protected override void OnInitialized()
    {
        inviteDto.HouseholdId = HouseholdId;
    }

    private async Task HandleSubmit()
    {
        isSubmitting = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            // Close dialog with the invite data as result
            MudDialog.Close(DialogResult.Ok(inviteDto));
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            isSubmitting = false;
        }
    }

    private void HandleCancel()
    {
        MudDialog.Cancel();
    }
}