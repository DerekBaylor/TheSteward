@namespace TheSteward.Shared.Components.HouseholdComponents
@using TheSteward.Core.Dtos.HouseholdDtos
@using TheSteward.Core.Models
@using System.Reflection
@using TheSteward.Core.Attributes

<MudCard id="userHouseholdCard" class="ts-tabbed-card" Elevation="0">
    <MudCardActions class="ts-tabbed-card-btn-container">
        <MudButton id="editPermissionsBtn" class="ts-card-tab-btn" @onclick="HandleEdit">Edit Permissions</MudButton>
        <MudButton id="closeMemberBtn" class="ts-card-tab-btn" @onclick="HandleCancel">Close</MudButton>
    </MudCardActions>

    <MudCardContent class="ts-card-content">
        <MudCardHeader Class="ts-tabbed-card-header">
            <h3 class="ts-tabbed-card-title">
                <span class="material-icons" style="vertical-align: middle; font-size: 24px; margin-right: 8px;">person</span>
                <span class="ts-label">@UserHouseholdDto.User.UserName</span>
            </h3>
        </MudCardHeader>

        <div class="ts-card-body">
            <section class="ts-card-section">
                <p class="ts-card-row">
                    <span class="ts-row-title">Household Owner:</span>
                    @(UserHouseholdDto.IsHouseholdOwner ? "Yes" : "No")
                </p>
            </section>

            <section class="ts-card-section">
                <p class="ts-label">Permissions:</p>
                <ul id="memberPermissionsList" class="ts-card-list">
                    @foreach (var permission in GetPermissions())
                    {
                        <li>
                            <span style="@(permission.IsEnabled ? "" : "opacity: 0.6;")">@permission.Name</span>
                            <span class="material-icons" style="@(permission.IsEnabled ? "color: green;" : "color: gray;") vertical-align: middle; font-size: 20px;">
                                @(permission.IsEnabled ? "check_circle" : "radio_button_unchecked")
                            </span>
                        </li>
                    }
                </ul>
            </section>
        </div>
    </MudCardContent>
</MudCard>

@code {
    [Parameter, EditorRequired]
    public UserHouseholdDto UserHouseholdDto { get; set; } = null!;

    [Parameter]
    public EventCallback OnCancel { get; set; }

    [Parameter]
    public EventCallback OnEdit { get; set; }

    private async Task HandleCancel()
    {
        await OnCancel.InvokeAsync();
    }

    private async Task HandleEdit()
    {
        await OnEdit.InvokeAsync();
    }

    private List<(string Name, bool IsEnabled)> GetPermissions()
    {
        var permission = new List<(string Name, bool IsEnabled)>();
        var properties = typeof(UserHouseholdDto).GetProperties()
            .Where(p => p.GetCustomAttribute<UserPermissionAttribute>() != null);

        foreach (var property in properties)
        {
            var attribute = property.GetCustomAttribute<UserPermissionAttribute>();
            var value = (bool)(property.GetValue(UserHouseholdDto) ?? false);
            permission.Add((attribute!.DisplayName, value));
        }

        return permission;
    }
}