@namespace TheSteward.Shared.Components.HouseholdComponents
@using TheSteward.Core.Models

<MudCard id="userProfileCard" class="ts-tabbed-card user-profile-card" Elevation="0">
    <MudCardActions class="ts-tabbed-card-btn-container">
        <MudButton id="editProfileBtn" class="ts-card-tab-btn" @onclick="HandleEdit">Edit Profile</MudButton>
        <MudButton id="closeProfileBtn" class="ts-card-tab-btn" @onclick="HandleClose">Close</MudButton>
    </MudCardActions>

    <MudCardContent class="ts-card-content">
        <MudCardHeader Class="ts-tabbed-card-header">
            <h3 class="ts-tabbed-card-title"><span class="ts-label">My Profile</span></h3>
        </MudCardHeader>

        <div class="ts-card-body">
            <section class="ts-card-section">
                <p class="ts-card-row">
                    <span class="ts-row-title">Username:</span> @User.UserName
                </p>
                <p class="ts-card-row">
                    <span class="ts-row-title">Email:</span> @User.Email
                </p>
                <p class="ts-card-row">
                    <span class="ts-row-title">Phone:</span> @(string.IsNullOrEmpty(User.PhoneNumber) ? "Not set" : User.PhoneNumber)
                </p>
            </section>
        </div>
    </MudCardContent>
</MudCard>

@code {
    [Parameter, EditorRequired]
    public ApplicationUser User { get; set; } = null!;

    [Parameter]
    public EventCallback OnEdit { get; set; }

    [Parameter]
    public EventCallback OnClose { get; set; }

    private async Task HandleEdit()
    {
        await OnEdit.InvokeAsync();
    }

    private async Task HandleClose()
    {
        await OnClose.InvokeAsync();
    }
}