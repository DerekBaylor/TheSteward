@namespace TheSteward.Shared.Components.HouseholdComponents
@using TheSteward.Shared.Dtos
@using TheSteward.Shared.Dtos.HouseholdDtos

<MudDialog Class="ts-modal user-profile-modal">
    <DialogContent>

        <MudElement Class="modal-layout">

            <MudStack Class="modal-sidebar">
                <MudElement Class="modal-sidebar-content">
                    <MudIcon Icon="@Icons.Material.Filled.Edit" />
                    <MudText Typo="Typo.h6">PROFILE</MudText>
                </MudElement>
            </MudStack>

            <MudStack Class="modal-right-stack">
                <EditForm Model="FormData" OnValidSubmit="HandleSubmit">
                    <DataAnnotationsValidator />

                    <MudTextField @bind-Value="FormData.UserName"
                                  Label="Username"
                                  Variant="Variant.Outlined"
                                  For="@(() => FormData.UserName)"
                                  Margin="Margin.Dense"
                                  Class="mb-4" />

                    <MudTextField @bind-Value="FormData.Email"
                                  Label="Email"
                                  Variant="Variant.Outlined"
                                  For="@(() => FormData.Email)"
                                  Margin="Margin.Dense"
                                  InputType="InputType.Email"
                                  Class="mb-4" />

                    <MudTextField @bind-Value="FormData.PhoneNumber"
                                  Label="Phone Number"
                                  Variant="Variant.Outlined"
                                  For="@(() => FormData.PhoneNumber)"
                                  Margin="Margin.Dense"
                                  InputType="InputType.Telephone"
                                  Placeholder="(555) 555-5555"
                                  Class="mb-4" />
                </EditForm>

                <MudElement Class="modal-actions">
                    <MudButton OnClick="HandleCancel"
                               Variant="Variant.Outlined">
                        Cancel
                    </MudButton>
                    <MudButton OnClick="HandleSubmit"
                               Variant="Variant.Filled"
                               Color="Color.Primary">
                        Update Profile
                    </MudButton>
                </MudElement>
            </MudStack>
        </MudElement>
    </DialogContent>

</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter, EditorRequired]
    public UserProfileFormDto FormData { get; set; } = new();

    private void HandleSubmit()
    {
        MudDialog.Close(DialogResult.Ok(FormData));
    }

    private void HandleCancel()
    {
        MudDialog.Cancel();
    }
}