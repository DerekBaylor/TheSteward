@using TheSteward.Core.Dtos.HouseholdDtos
@using TheSteward.Core.IServices.HouseholdIServices
@using TheSteward.Shared.Dtos.HouseholdDtos
@using System.Security.Claims
@using TheSteward.Shared.Models
@using TheSteward.Shared.Components

@inject IUserHouseholdService UserHouseholdService
@inject HouseholdState HouseholdState
@inject AuthenticationStateProvider AuthenticationStateProvider

@implements IDisposable

@namespace TheSteward.Shared.Components

@if (isLoading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (householdItems.Count > 0)
{
    <MudToolBar Class="household-toolbar" WrapContent="true">
        <div class="toolbar-select-group">
            <label class="select-label">
                <span class="material-icons">home</span>
                Active Household
            </label>
            @if (householdItems.Count == 1)
            {
                <span class="toolbar-household-name">
                    @HouseholdState.CurrentHousehold?.HouseholdName
                </span>
            }
            else
            {
                <TsSelect TValue="Guid?"
                          Items="householdItems"
                          @bind-Value="selectedHouseholdId"
                          OnChange="OnHouseholdChangedAsync"
                          Placeholder="Choose household" />
            }

        </div>

        @if (ChildContent != null)
        {
            <div class="toolbar-actions">
                @ChildContent
            </div>
        }
    </MudToolBar>
}
else
{
    <MudAlert Severity="Severity.Warning">
        Toolbar: no households found for user "@currentUserId"
    </MudAlert>
    @if (errorMessage != null)
    {
        <MudAlert Severity="Severity.Error">@errorMessage</MudAlert>
    }
}

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public EventCallback<UserHouseholdDto> OnHouseholdChanged { get; set; }

    private List<SelectItem<Guid?>> householdItems = new();
    private List<UserHouseholdDto> userHouseholds = new();
    private Guid? selectedHouseholdId;
    private bool isLoading = true;
    private string? currentUserId;
    private Action? _stateChangeHandler;

    private string? errorMessage;

    protected override Task OnInitializedAsync()
    {
        _stateChangeHandler = () => InvokeAsync(StateHasChanged);
        HouseholdState.OnChange += _stateChangeHandler;

        householdItems = HouseholdState.UserHouseholds.Select(uh => new SelectItem<Guid?>
        {
            Value = uh.HouseholdId,
            Text = uh.Household?.HouseholdName ?? "Unknown"
        }).ToList();

        selectedHouseholdId = HouseholdState.CurrentHousehold?.HouseholdId;
        isLoading = false;

        return Task.CompletedTask;
    }

    private async Task OnHouseholdChangedAsync()
    {
        var selected = HouseholdState.UserHouseholds  // was: userHouseholds
            .FirstOrDefault(uh => uh.HouseholdId == selectedHouseholdId);
        
        if (selected == null) return;

        HouseholdState.SetUserHousehold(selected);
        await OnHouseholdChanged.InvokeAsync(selected);
    }

    public void Dispose() => HouseholdState.OnChange -= _stateChangeHandler;
}