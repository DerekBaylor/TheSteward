@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Authorization
@using TheSteward.Shared.Models
@using TheSteward.Shared.Services
@using TheSteward.Shared.Interfaces
@using TheSteward.Core.Dtos.HouseholdDtos
@using Microsoft.AspNetCore.Identity

@implements IDisposable

@inject INavigationService NavigationService
@inject NavigationManager NavigationManager
@inject HouseholdState HouseholdState
@inject AuthenticationStateProvider AuthStateProvider

@namespace TheSteward.Shared.Components

<nav id="mainSidebar" class="sidebar">

    <NavLink href="/"
             class="nav-img-container"
             @onclick="@(() => HandleNavClick(new NavItem("Dashboard", "dashboard", "/", true, false)))">

        <img src="/Assets/Images/TheSteward_264x563.webp" alt="a cartoon man in a black suit wearing glasses" class="nav-image" />
        <a class="nav-brand-text" href="">The Steward</a>
    </NavLink>

    @foreach (var item in GetFilteredNavigationItems())
    {
        <AuthorizeView>
            <Authorized>
                @if (item.RequiresAuth)
                {
                    @if (!item.IsLogout)
                    {
                        <NavLink href="@item.Route"
                                 class="nav-link-group"
                                 Match="NavLinkMatch.All"
                                 @onclick="() => HandleNavClick(item)">
                            <span class="nav-icon">
                                <span class="material-symbols-outlined">@item.MaterialIcon</span>
                            </span>
                            <span class="nav-title">@item.Title</span>
                        </NavLink>
                    }
                    else
                    {
                        <form @formname="logoutForm" method="post" action="/account/logout" class="nav-link-group-form">
                            <AntiforgeryToken />
                            <button type="submit" class="nav-link-group logout-button">
                                <span class="nav-icon">
                                    <span class="material-symbols-outlined">@item.MaterialIcon</span>
                                </span>
                                <span class="nav-title">@item.Title</span>
                            </button>
                        </form>
                    }
                }
            </Authorized>
            <NotAuthorized>
                @if (!item.RequiresAuth)
                {
                    @if (!item.IsLogout)
                    {
                        <NavLink href="@item.Route"
                                 class="nav-link-group"
                                 Match="NavLinkMatch.All"
                                 @onclick="() => HandleNavClick(item)">
                            <span class="nav-icon">
                                <span class="material-symbols-outlined">@item.MaterialIcon</span>
                            </span>
                            <span class="nav-title">@item.Title</span>
                        </NavLink>
                    }
                }
            </NotAuthorized>
        </AuthorizeView>
    }
</nav>

@code {
    private UserHouseholdDto? _currentUserHousehold;

    protected override async Task OnInitializedAsync()
    {
        NavigationService.OnChange += HandleStateChange;
        HouseholdState.OnChange += HandleStateChange;

        await LoadCurrentUserHousehold();
    }

    private void HandleStateChange()
    {
        InvokeAsync(async () =>
        {
            await LoadCurrentUserHousehold();
            StateHasChanged();
        });
    }

    private async Task LoadCurrentUserHousehold()
    {
        if (HouseholdState.CurrentHousehold == null) return;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        if (string.IsNullOrEmpty(userId)) return;

        _currentUserHousehold = HouseholdState.CurrentHousehold.UserHouseholdDtos
            .FirstOrDefault(uh => uh.UserId == userId);

        await InvokeAsync(StateHasChanged);
    }

    public List<NavItem> GetNavigationItems()
    {
        return new List<NavItem>
        {
            new("Dashboard", "dashboard", "/", true, false),
            new("Household", "home", "/household", true, false),
            new("Budget", "finance", "/budget", true, false),
            new("Kitchen", "kitchen", "/kitchen", true, false),
            new("Tasks", "checklist", "/tasks", true, false),
            new("Files", "folder", "/files", true, false),
            new("Register", "app_registration", "/account/register", false, false),
            new("Logout", "logout", "/", true, true),
            new("Login", "login", "/account/login", false, false),
        };
    }

    private List<NavItem> GetFilteredNavigationItems()
    {
        var items = GetNavigationItems();

        if (HouseholdState.CurrentHousehold == null || _currentUserHousehold == null)
        {
            return items.Where(item =>
                !item.RequiresAuth ||
                item.Route == "/household" ||
                item.IsLogout
            ).ToList();
        }

        var household = HouseholdState.CurrentHousehold;
        var userPerms = _currentUserHousehold;

        return items.Where(item =>
        {
            if (!item.RequiresAuth) return true;

            if (item.Route == "/" || item.IsLogout) return true;

            return item.Route switch
            {
                "/household" => true,
                "/budget" => household.HasFinanceManagerAccess &&
                            userPerms.HasFinanceManagerReadPermission,
                "/kitchen" => household.HasKitchenManagerAccess &&
                             userPerms.HasKitchenManagerReadPermission,
                "/tasks" => household.HasTaskManagerAccess &&
                           userPerms.HasTaskManagerReadPermission,
                "/files" => household.HasFileManagerAccess &&
                            userPerms.HasFileManagerReadPermission,
                _ => true
            };
        }).ToList();
    }

    private void HandleNavClick(NavItem item)
    {
        NavigationService.SetMainSection(item.Title);
    }

    public void Dispose()
    {
        NavigationService.OnChange -= HandleStateChange;

        HouseholdState.OnChange -= () => InvokeAsync(StateHasChanged);
    }
}