@using TheSteward.Core.Dtos.HouseholdDtos
@using TheSteward.Shared.Dtos.HouseholdDtos
@using TheSteward.Shared.Models
@using TheSteward.Shared.Components
@using static TheSteward.Core.Utils.TaskManagerUtils.TaskManagerConstants

@inject HouseholdState HouseholdState

@implements IDisposable

@namespace TheSteward.Shared.Components.TaskManagerComponents

@if (isLoading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (householdItems.Count > 0)
{
    <MudToolBar Class="tm-toolbar-bar">

        @* Household Selector *@
        <div class="toolbar-select-group">
            <label class="select-label">
                <span class="material-symbols-outlined">home</span>
                Active Household
            </label>
            @if (householdItems.Count == 1)
            {
                <span class="toolbar-household-name">
                    @HouseholdState.CurrentHousehold?.HouseholdName
                </span>
            }
            else
            {
                <TsSelect TValue="Guid?"
                          Items="householdItems"
                          @bind-Value="selectedHouseholdId"
                          OnChange="OnHouseholdChangedAsync"
                          Placeholder="Choose household"
                          Variant="blue" />
            }
        </div>

        <MudSpacer />

        @* Toolbar Action Buttons *@
        @if (HouseholdState.HasTaskManagerWritePermission)
        {
            <div class="toolbar-action-group">
                <MudButton Color="Color.Primary" Variant="Variant.Filled" Class="toolbar-btn"
                        @onclick="OnAddTaskClicked">
                    <span class="material-symbols-outlined">add</span>
                    Add Task
                </MudButton>
                <MudButton Color="Color.Primary" Variant="Variant.Filled" Class="toolbar-btn"
                        @onclick="OnAddCategoryClicked">
                    <span class="material-symbols-outlined">create_new_folder</span>
                    Add Category
                </MudButton>

                <MudTooltip Text="Add Standard Tasks">
                    <MudIconButton Icon="@Icons.Material.Filled.PlaylistAdd"
                                   Color="Color.Secondary"
                                   OnClick="OnAddStandardTasks" />
                </MudTooltip>

            </div>
        }

    </MudToolBar>
}
else
{
    <MudAlert Severity="Severity.Warning">
        Toolbar: no households found.
    </MudAlert>
}

@code {
    [Parameter]
    public EventCallback<UserHouseholdDto> OnHouseholdChanged { get; set; }

    [Parameter]
    public EventCallback OnAddTask { get; set; }

    [Parameter]
    public EventCallback OnAddCategory { get; set; }

    [Parameter] 
    public EventCallback OnAddStandardTasks { get; set; }

    private List<SelectItem<Guid?>> householdItems = new();
    private Guid? selectedHouseholdId;
    private bool isLoading = true;
    private Action? _stateChangeHandler;

    protected override Task OnInitializedAsync()
    {
        _stateChangeHandler = () => InvokeAsync(StateHasChanged);
        HouseholdState.OnChange += _stateChangeHandler;

        householdItems = HouseholdState.UserHouseholds.Select(uh => new SelectItem<Guid?>
        {
            Value = uh.HouseholdId,
            Text = uh.Household?.HouseholdName ?? "Unknown"
        }).ToList();

        selectedHouseholdId = HouseholdState.CurrentHousehold?.HouseholdId;
        isLoading = false;

        return Task.CompletedTask;
    }

    private async Task OnHouseholdChangedAsync()
    {
        var selected = HouseholdState.UserHouseholds
            .FirstOrDefault(uh => uh.HouseholdId == selectedHouseholdId);

        if (selected == null) return;

        HouseholdState.SetUserHousehold(selected);
        await OnHouseholdChanged.InvokeAsync(selected);
    }

    private async Task OnAddTaskClicked()
    {
        if (OnAddTask.HasDelegate)
            await OnAddTask.InvokeAsync();
    }

    private async Task OnAddCategoryClicked()
    {
        if (OnAddCategory.HasDelegate)
            await OnAddCategory.InvokeAsync();
    }

    public void Dispose() => HouseholdState.OnChange -= _stateChangeHandler;
}


