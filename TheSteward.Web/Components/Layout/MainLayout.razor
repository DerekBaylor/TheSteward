@inherits LayoutComponentBase
@implements IDisposable
@inject INavigationService NavigationService

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout class="app-container">
    <MudDrawer Open="true">
        <SidebarNav />
    </MudDrawer>
    <MudMainContent class="main-content">
        @Body
    </MudMainContent>
</MudLayout>

@code {
    protected override void OnInitialized()
    {
        NavigationService.OnChange += () => InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        NavigationService.OnChange -= () => InvokeAsync(StateHasChanged);
    }
}