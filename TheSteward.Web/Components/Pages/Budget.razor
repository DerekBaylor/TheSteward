@page "/budget"

@using Microsoft.AspNetCore.Authorization
@using TheSteward.Shared.Dtos.HouseholdDtos

@inject HouseholdState HouseholdState
@inject NavigationManager NavigationManager

@attribute [Authorize]
@implements IDisposable

<PageTitle>Budget Dashboard</PageTitle>

<HouseholdToolBar OnHouseholdChanged="OnHouseholdChanged" />

@if (HouseholdState.CurrentUserHousehold == null)
{
    <MudAlert Severity="Severity.Warning" Class="mt-4">
        You are not part of a household. Please visit the
        <MudLink Href="/household">Household page</MudLink> to get started.
    </MudAlert>
}
else if (!HouseholdState.CurrentHousehold!.HasFinanceManagerAccess)
{
    <MudAlert Severity="Severity.Warning" Class="mt-4">
        This household does not have Finance Manager enabled. An admin can enable it in
        <MudLink Href="/household">Household Settings</MudLink>.
    </MudAlert>
}
else if (!HouseholdState.HasFinanceReadPermission)
{
    <MudAlert Severity="Severity.Error" Class="mt-4">
        You do not have permission to view finances for this household.
        Please contact your household admin.
    </MudAlert>
}
else
{
    <MudText Typo="Typo.h5" Class="mt-4">
        Budget — @HouseholdState.CurrentHousehold.HouseholdName
    </MudText>

    <!-- Budget content goes here -->
    // Income Component
    // Expense Component
    // Invesetment Component
    // Credit Component
    // Budget Summary Component
}

@code {
    private Action? _stateChangeHandler;

    protected override void OnInitialized()
    {
        _stateChangeHandler = () => InvokeAsync(StateHasChanged);
        HouseholdState.OnChange += _stateChangeHandler;
    }

    private void OnHouseholdChanged(UserHouseholdDto _) { }

    public void Dispose() => HouseholdState.OnChange -= _stateChangeHandler;
}