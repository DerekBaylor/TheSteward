@if (!string.IsNullOrEmpty(errorMessage))
{
    <MudAlert Severity="Severity.Error" Class="mt-3">@errorMessage</MudAlert>
}

@code {
    private bool isLoading = true;
    private bool isCreating = false;
    private bool hasBudget = false;
    private string? creatingType;
    private string? errorMessage;
    private BudgetDto? currentBudget;
    private Action? _stateChangeHandler;

    // Investment
    private Task OpenAddInvestmentModal() => Task.CompletedTask; // TODO: Implement
    private Task OpenEditInvestmentModal(InvestmentDto investment) => Task.CompletedTask; // TODO: Implement

    // Credit
    private Task OpenAddCreditModal() => Task.CompletedTask; // TODO: Implement
    private Task OpenEditCreditModal(CreditDto credit) => Task.CompletedTask; // TODO: Implement

    // Expense
    private Task OpenAddExpenseModal() => Task.CompletedTask; // TODO: Implement
    private Task OpenEditExpenseModal(ExpenseDto expense) => Task.CompletedTask; // TODO: Implement

    protected override async Task OnInitializedAsync()
    {
        _stateChangeHandler = () => InvokeAsync(StateHasChanged);
        HouseholdState.OnChange += _stateChangeHandler;

        await LoadBudgetAsync();
    }
    #region Budget
    private async Task LoadBudgetAsync()
    {
        var householdId = HouseholdState.CurrentHousehold?.HouseholdId;
        var userHousehold = HouseholdState.CurrentUserHousehold;

        if (householdId == null || userHousehold == null || !HouseholdState.HasFinanceReadPermission)
        {
            isLoading = false;
            return;
        }

        try
        {
            isLoading = true;

            var budgets = await BudgetService.GetBudgetsForUserHouseholdAsync(userHousehold);

            currentBudget = budgets.FirstOrDefault(b => b.BudgetId == userHousehold.DefaultBudgetId)
                ?? budgets.FirstOrDefault(b => b.IsDefaultBudget)
                ?? budgets.FirstOrDefault();

            hasBudget = currentBudget != null;
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading budget: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task CreateStarterBudget()
    {
        if (isCreating) return;
        await CreateBudget("starter");
    }

    private async Task CreateBlankBudget()
    {
        if (isCreating) return;
        await CreateBudget("blank");
    }

    private async Task CreateBudget(string type)
    {
        var householdId = HouseholdState.CurrentHousehold?.HouseholdId;
        var userHousehold = HouseholdState.CurrentUserHousehold;

        if (householdId == null || userHousehold == null) return;

        isCreating = true;
        creatingType = type;
        errorMessage = null;

        try
        {
            if (type == "starter")
            {
                currentBudget = await BudgetService.AddStarterBudget(userHousehold);
            }
            else
            {
                currentBudget = await BudgetService.AddAsync(new CreateBudgetDto
                {
                    BudgetName = "My Budget",
                    HouseholdId = householdId.Value,
                    OwnerId = userHousehold.UserId,
                    IsDefaultBudget = true,
                    IsPublic = false
                });
            }

            // Set as the user's default budget for this household
            await UserHouseholdService.SetDefaultBudgetAsync(userHousehold.UserHouseholdId, currentBudget!.BudgetId);

            hasBudget = true;
            Snackbar.Add("Budget created successfully!", Severity.Success);
        }
        catch (Exception ex)
        {
            errorMessage = $"Error creating budget: {ex.Message}";
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            isCreating = false;
            creatingType = null;
        }
    }

    private async void OnHouseholdChanged(UserHouseholdDto _)
    {
        currentBudget = null;
        hasBudget = false;
        errorMessage = null;
        await LoadBudgetAsync();
    }
    #endregion Budget

    #region Income
    private async Task OpenAddIncomeModal()
    {
        var formData = new IncomeFormDto
        {
            BudgetId = currentBudget!.BudgetId,
            DisplayOrder = currentBudget.Incomes.Count
        };

        await OpenIncomeModal(formData);
    }

    private async Task OpenEditIncomeModal(IncomeDto income)
    {
        var formData = new IncomeFormDto
        {
            IncomeId = income.IncomeId,
            IncomeName = income.IncomeName,
            IncomeFrequency = income.IncomeFrequency,
            PayCheckGross = income.PayCheckGross,
            DisplayOrder = income.DisplayOrder,
            BudgetId = income.BudgetId
        };

        await OpenIncomeModal(formData);
    }

    private async Task OpenIncomeModal(IncomeFormDto formData)
    {
        var parameters = new DialogParameters
    {
        { "FormData", formData },
        { "ExistingIncomeCount", currentBudget!.Incomes.Count }
    };

        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<IncomeModal>(
            formData.IsEditMode ? "Edit Income" : "Add Income",
            parameters,
            options);

        var result = await dialog.Result;

        if (result.Canceled) return;

        if (result.Data is string signal && signal.StartsWith("delete:"))
        {
            var id = Guid.Parse(signal.Replace("delete:", ""));
            await HandleDeleteIncome(id);
            return;
        }

        var budgets = await BudgetService.GetBudgetsForUserHouseholdAsync(
            HouseholdState.CurrentUserHousehold!);

        currentBudget = budgets.FirstOrDefault(b => b.BudgetId == currentBudget!.BudgetId)
            ?? currentBudget;

        StateHasChanged();
    }

    private async Task HandleDeleteIncome(Guid incomeId)
    {
        try
        {
            await IncomeService.DeleteAsync(incomeId);
            currentBudget!.Incomes.RemoveAll(i => i.IncomeId == incomeId);
            Snackbar.Add("Income removed.", Severity.Success);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error deleting income: {ex.Message}", Severity.Error);
        }
    }
    #endregion Income

    public void Dispose() => HouseholdState.OnChange -= _stateChangeHandler;
}