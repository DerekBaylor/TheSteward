@page "/budget"

@using Microsoft.AspNetCore.Authorization
@using TheSteward.Infrastructure.Services.FinanceManagerServices
@using TheSteward.Infrastructure.Services.HouseholdServices
@using TheSteward.Shared.Components.FinanceManagerComponents
@using TheSteward.Shared.Dtos.HouseholdDtos
@using TheSteward.Core.Dtos.FinanceManagerDtos
@using TheSteward.Core.IServices.FinanceManagerIServices
@using TheSteward.Shared.Components
@using TheSteward.Shared.Dtos.BudgetDtos

@inject HouseholdState HouseholdState
@inject NavigationManager NavigationManager
@inject IBudgetService BudgetService
@inject IIncomeService IncomeService
@inject IInvestmentService InvestmentService
@inject ICreditService CreditService
@inject IUserHouseholdService UserHouseholdService
@inject ISnackbar Snackbar
@inject IDialogService DialogService

@attribute [Authorize]
@implements IDisposable

<PageTitle>Budget Dashboard</PageTitle>

<HouseholdToolBar OnHouseholdChanged="OnHouseholdChanged" />

@if (HouseholdState.CurrentUserHousehold == null)
{
    <MudAlert Severity="Severity.Warning" Class="mt-4">
        You are not part of a household. Please visit the
        <MudLink Href="/household">Household page</MudLink> to get started.
    </MudAlert>
}
else if (!HouseholdState.CurrentHousehold!.HasFinanceManagerAccess)
{
    <MudAlert Severity="Severity.Warning" Class="mt-4">
        This household does not have Finance Manager enabled. An admin can enable it in
        <MudLink Href="/household">Household Settings</MudLink>.
    </MudAlert>
}
else if (!HouseholdState.HasFinanceReadPermission)
{
    <MudAlert Severity="Severity.Error" Class="mt-4">
        You do not have permission to view finances for this household.
        Please contact your household admin.
    </MudAlert>
}
else if (isLoading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mt-4" />
}
else if (!hasBudget)
{


    <div class="d-flex flex-column align-center justify-center mt-8" style="gap: 1.5rem;">
        <MudIcon Icon="@Icons.Material.Outlined.AccountBalanceWallet" 
                 Style="font-size: 4rem; color: var(--mud-palette-text-secondary);" />
        <MudText Typo="Typo.h5">Need a budget?</MudText>
        <MudText Typo="Typo.body1" Align="Align.Center" Color="Color.Secondary">
            Get started by creating a budget for <strong>@HouseholdState.CurrentHousehold!.HouseholdName</strong>.
        </MudText>

        <div class="d-flex flex-row" style="gap: 1rem; flex-wrap: wrap; justify-content: center;">
            <MudCard Style="max-width: 280px; cursor: pointer;" @onclick="CreateStarterBudget">
                <MudCardContent Class="d-flex flex-column align-center pa-6" style="gap: 0.75rem;">
                    <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Color="Color.Primary" Style="font-size: 2.5rem;" />
                    <MudText Typo="Typo.h6">Starter Budget</MudText>
                    <MudText Typo="Typo.body2" Align="Align.Center" Color="Color.Secondary">
                        Pre-filled with common categories and sample data to help you get started quickly.
                    </MudText>
                </MudCardContent>
                <MudCardActions Class="justify-center pb-4">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" 
                               Disabled="isCreating" OnClick="CreateStarterBudget">
                        @if (isCreating && creatingType == "starter")
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        }
                        Use Starter Budget
                    </MudButton>
                </MudCardActions>
            </MudCard>

            <MudCard Style="max-width: 280px; cursor: pointer;" @onclick="CreateBlankBudget">
                <MudCardContent Class="d-flex flex-column align-center pa-6" style="gap: 0.75rem;">
                    <MudIcon Icon="@Icons.Material.Filled.NoteAdd" Color="Color.Secondary" Style="font-size: 2.5rem;" />
                    <MudText Typo="Typo.h6">Blank Budget</MudText>
                    <MudText Typo="Typo.body2" Align="Align.Center" Color="Color.Secondary">
                        Start from scratch and build your budget exactly the way you want it.
                    </MudText>
                </MudCardContent>
                <MudCardActions Class="justify-center pb-4">
                    <MudButton Variant="Variant.Outlined" Color="Color.Secondary" 
                               Disabled="isCreating" OnClick="CreateBlankBudget">
                        @if (isCreating && creatingType == "blank")
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        }
                        Start Blank
                    </MudButton>
                </MudCardActions>
            </MudCard>
        </div>
    </div>
}
else
{
    <div class="budget-layout">

        <div class="budget-col-left">
            <IncomeCard Incomes="currentBudget.Incomes"
                        IsReadOnly="!HouseholdState.HasFinanceWritePermission"
                        OnAddIncome="OpenAddIncomeModal"
                        OnOpenIncomeDetails="OpenIncomeDetails"
                        OnEditIncome="OpenEditIncomeModal"
                        OnDeleteIncome="(income) => HandleDeleteIncome(income.IncomeId)" />

            <InvestmentCard Investments="currentBudget.Investments"
                            IsReadOnly="!HouseholdState.HasFinanceWritePermission"
                            OnAddInvestment="OpenAddInvestmentModal"
                            OnOpenInvestmentDetails="OpenInvestmentDetails"
                            OnEditInvestment="OpenEditInvestmentModal"
                            OnDeleteInvestment="(investment) => HandleDeleteInvestment(investment.InvestmentId)" />

            <CreditCard Credits="currentBudget.Credits"
                        IsReadOnly="!HouseholdState.HasFinanceWritePermission"
                        OnAddCredit="OpenAddCreditModal"
                        OnOpenCreditDetails="OpenCreditDetails"
                        OnEditCredit="OpenEditCreditModal"
                        OnDeleteCredit="(credit) => HandleDeleteCredit(credit.CreditId)" />
        </div>

        <div class="budget-col-right">
            <ExpenseCard Expenses="currentBudget.Expenses"
                         IsReadOnly="!HouseholdState.HasFinanceWritePermission"
                         OnAddExpense="OpenAddExpenseModal"
                         OnOpenExpenseDetails="OpenExpenseDetails"
                         OnEditExpense="OpenEditExpenseModal" 
                         OnDeleteExpense="(expense) => HandleDeleteExpense(expense.ExpenseId)"/>
                </div>

        </div>


}

@if (!string.IsNullOrEmpty(errorMessage))
{
    <MudAlert Severity="Severity.Error" Class="mt-3">@errorMessage</MudAlert>
}

@code {
    private bool isLoading = true;
    private bool isCreating = false;
    private bool hasBudget = false;
    private string? creatingType;
    private string? errorMessage;
    private BudgetDto? currentBudget;
    private Action? _stateChangeHandler;


    protected override async Task OnInitializedAsync()
    {
        _stateChangeHandler = () => InvokeAsync(StateHasChanged);
        HouseholdState.OnChange += _stateChangeHandler;

        await LoadBudgetAsync();
    }

    private async void OnHouseholdChanged(UserHouseholdDto _)
    {
        currentBudget = null;
        hasBudget = false;
        errorMessage = null;
        await LoadBudgetAsync();
        StateHasChanged();
    }

    #region Budget
    private async Task LoadBudgetAsync()
    {
        var householdId = HouseholdState.CurrentHousehold?.HouseholdId;
        var userHousehold = HouseholdState.CurrentUserHousehold;

        if (householdId == null || userHousehold == null || !HouseholdState.HasFinanceReadPermission)
        {
            isLoading = false;
            return;
        }

        try
        {
            isLoading = true;

            var budgets = await BudgetService.GetBudgetsForUserHouseholdAsync(userHousehold);

            currentBudget = budgets.FirstOrDefault(b => b.BudgetId == userHousehold.DefaultBudgetId)
                ?? budgets.FirstOrDefault(b => b.IsDefaultBudget)
                ?? budgets.FirstOrDefault();

            hasBudget = currentBudget != null;
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading budget: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task CreateStarterBudget()
    {
        if (isCreating) return;
        await CreateBudget("starter");
    }

    private async Task CreateBlankBudget()
    {
        if (isCreating) return;
        await CreateBudget("blank");
    }

    private async Task CreateBudget(string type)
    {
        var householdId = HouseholdState.CurrentHousehold?.HouseholdId;
        var userHousehold = HouseholdState.CurrentUserHousehold;

        if (householdId == null || userHousehold == null) return;

        isCreating = true;
        creatingType = type;
        errorMessage = null;

        try
        {
            if (type == "starter")
            {
                currentBudget = await BudgetService.AddStarterBudget(userHousehold);
            }
            else
            {
                currentBudget = await BudgetService.AddAsync(new CreateBudgetDto
                {
                    BudgetName = "My Budget",
                    HouseholdId = householdId.Value,
                    OwnerId = userHousehold.UserId,
                    IsDefaultBudget = true,
                    IsPublic = false
                });
            }

            await UserHouseholdService.SetDefaultBudgetAsync(userHousehold.UserHouseholdId, currentBudget!.BudgetId);

            hasBudget = true;
            Snackbar.Add("Budget created successfully!", Severity.Success);
        }
        catch (Exception ex)
        {
            errorMessage = $"Error creating budget: {ex.Message}";
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            isCreating = false;
            creatingType = null;
        }
    }
    #endregion Budget

    #region Income
    private async Task OpenAddIncomeModal()
    {
        var formData = new IncomeFormDto
        {
            BudgetId = currentBudget!.BudgetId,
            DisplayOrder = currentBudget.Incomes.Count
            //TODO: Get filing status from other incomes else be single
        };

        await OpenIncomeModal(formData);
    }

    private async Task OpenIncomeDetails()
    {
        if (currentBudget == null) return;

        var parameters = new DialogParameters
    {
        { "Incomes", currentBudget.Incomes }
    };

        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };

        await DialogService.ShowAsync<IncomeDetailsModal>(
            "Income Details",
            parameters,
            options);
    }

    private async Task OpenEditIncomeModal(IncomeDto income)
    {
        var formData = new IncomeFormDto
        {
            IncomeId = income.IncomeId,
            IncomeName = income.IncomeName,
            IncomeFrequency = income.IncomeFrequency,
            FilingStatus = income.FilingStatus,
            PayCheckGross = income.PayCheckGross,
            DisplayOrder = income.DisplayOrder,
            BudgetId = income.BudgetId
        };

        await OpenIncomeModal(formData);
    }

    private async Task OpenIncomeModal(IncomeFormDto formData)
    {
        var budgetIncomes = new List<IncomeDto>();

        if (currentBudget != null)
        {            
            budgetIncomes = currentBudget.Incomes;
        }

        var parameters = new DialogParameters
        {
            { "FormData", formData },
            { "ExistingIncomeCount", currentBudget!.Incomes.Count }
        };

        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<IncomeModal>(
            formData.IsEditMode ? "Edit Income" : "Add Income",
            parameters,
            options);

        var result = await dialog.Result;

        if (result.Canceled) return;

        if (result.Data is string resultData && resultData.StartsWith("delete:"))
        {
            var idString = resultData["delete:".Length..];
            if (Guid.TryParse(idString, out var incomeId))
                await HandleDeleteIncome(incomeId);
            return;
        }

        var budgets = await BudgetService.GetBudgetsForUserHouseholdAsync(
             HouseholdState.CurrentUserHousehold!);

        currentBudget = budgets.FirstOrDefault(b => b.BudgetId == currentBudget!.BudgetId)
            ?? currentBudget;

        StateHasChanged();
    }

    private async Task HandleDeleteIncome(Guid incomeId)
    {
        try
        {
            await IncomeService.DeleteAsync(incomeId);

            var budgets = await BudgetService.GetBudgetsForUserHouseholdAsync(
                HouseholdState.CurrentUserHousehold!);

            currentBudget = budgets.FirstOrDefault(b => b.BudgetId == currentBudget!.BudgetId)
                ?? currentBudget;

            Snackbar.Add("Income removed.", Severity.Success);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error deleting income: {ex.Message}", Severity.Error);
        }
    }
    #endregion Income

    #region Investment

    private async Task OpenAddInvestmentModal()
    {
        var formData = new InvestmentFormDto
        {
            BudgetId = currentBudget!.BudgetId
        };

        await OpenInvestmentModal(formData);
    }

    private async Task OpenInvestmentDetails()
    {
        if (currentBudget == null) return;

        var parameters = new DialogParameters
    {
        { "Investments", currentBudget.Investments }
    };

        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };

        await DialogService.ShowAsync<InvestmentDetailsModal>(
            "Investment Details",
            parameters,
            options);
    }

    private async Task OpenEditInvestmentModal(InvestmentDto investment)
    {
        var formData = new InvestmentFormDto
        {
            InvestmentId = investment.InvestmentId,
            InvestmentName = investment.InvestmentName,
            CurrentValue = investment.CurrentValue,
            InterestRate = investment.InterestRate,
            ContributionAmount = investment.ContributionAmount,
            ContributionFrequency = investment.ContributionFrequency,
            EstYearlyGrowth = investment.EstYearlyGrowth,
            DisplayOrder = investment.DisplayOrder,
            BudgetId = investment.BudgetId,
            ExpenseId = investment.ExpenseId
        };

        await OpenInvestmentModal(formData);
    }

    private async Task OpenInvestmentModal(InvestmentFormDto formData)
    {
        var parameters = new DialogParameters
    {
        { "FormData", formData },
        { "ExistingInvestmentCount", currentBudget!.Investments.Count }
    };

        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<InvestmentModal>(
            formData.IsEditMode ? "Edit Investment" : "Add Investment",
            parameters,
            options);

        var result = await dialog.Result;

        if (result.Canceled) return;

        if (result.Data is string resultData && resultData.StartsWith("delete:"))
        {
            var idString = resultData["delete:".Length..];
            if (Guid.TryParse(idString, out var investmentId))
                await HandleDeleteInvestment(investmentId);
            return;
        }

        var budgets = await BudgetService.GetBudgetsForUserHouseholdAsync(
            HouseholdState.CurrentUserHousehold!);

        currentBudget = budgets.FirstOrDefault(b => b.BudgetId == currentBudget!.BudgetId)
            ?? currentBudget;

        StateHasChanged();
    }

    private async Task HandleDeleteInvestment(Guid investmentId)
    {
        try
        {
            await InvestmentService.DeleteAsync(investmentId);

            var budgets = await BudgetService.GetBudgetsForUserHouseholdAsync(
                HouseholdState.CurrentUserHousehold!);

            currentBudget = budgets.FirstOrDefault(b => b.BudgetId == currentBudget!.BudgetId)
                ?? currentBudget;

            Snackbar.Add("Investment removed.", Severity.Success);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error deleting investment: {ex.Message}", Severity.Error);
        }
    }

    #endregion Investment

    #region Credit

    private async Task OpenAddCreditModal()
    {
        var formData = new CreditFormDto
        {
            BudgetId = currentBudget!.BudgetId,
            DisplayOrder = currentBudget.Credits.Count,
            BudgetCategoryName = "Debt & Credit"
        };

        await OpenCreditModal(formData);
    }

    private async Task OpenCreditDetails()
    {
        if (currentBudget == null) return;

        var parameters = new DialogParameters
        {
            { "Credits", currentBudget.Credits }
        };

        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };

        await DialogService.ShowAsync<CreditDetailsModal>(
            "Credit & Debt Details",
            parameters,
            options);
    }

    private async Task OpenEditCreditModal(CreditDto credit)
    {
        var formData = new CreditFormDto
        {
            CreditId = credit.CreditId,
            CreditName = credit.CreditName,
            CreditType = credit.CreditType,
            InterestRate = credit.InterestRate,
            CurrentValue = credit.CurrentValue,
            PaymentAmount = credit.PaymentAmount,
            PaymentFrequency = credit.PaymentFrequency,
            PaymentDay = credit.PaymentDay,
            EstMonthlyInterest = credit.EstMonthlyInterest,
            EstYearlyInterest = credit.EstYearlyInterest,
            DisplayOrder = credit.DisplayOrder,
            BudgetId = credit.BudgetId,
            ExpenseId = credit.ExpenseId
        };

        await OpenCreditModal(formData);
    }

    private async Task OpenCreditModal(CreditFormDto formData)
    {
        var parameters = new DialogParameters
        {
            { "FormData", formData },
            { "ExistingCreditCount", currentBudget!.Credits.Count }
        };

        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<CreditModal>(
            formData.IsEditMode ? "Edit Credit" : "Add Credit",
            parameters,
            options);

        var result = await dialog.Result;

        if (result.Canceled) return;

        if (result.Data is string resultData && resultData.StartsWith("delete:"))
        {
            var idString = resultData["delete:".Length..];
            if (Guid.TryParse(idString, out var creditId))
                await HandleDeleteCredit(creditId);
            return;
        }

        var budgets = await BudgetService.GetBudgetsForUserHouseholdAsync(
            HouseholdState.CurrentUserHousehold!);

        currentBudget = budgets.FirstOrDefault(b => b.BudgetId == currentBudget!.BudgetId)
            ?? currentBudget;

        StateHasChanged();
    }

    private async Task HandleDeleteCredit(Guid creditId)
    {
        try
        {
            await CreditService.DeleteAsync(creditId);

            var budgets = await BudgetService.GetBudgetsForUserHouseholdAsync(
                HouseholdState.CurrentUserHousehold!);

            currentBudget = budgets.FirstOrDefault(b => b.BudgetId == currentBudget!.BudgetId)
                ?? currentBudget;

            Snackbar.Add("Credit and linked expense removed.", Severity.Success);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error deleting credit: {ex.Message}", Severity.Error);
        }
    }

    #endregion Credit

    #region Expense
    private Task OpenAddExpenseModal()
    {
        Snackbar.Add("Add Expense — coming soon.", Severity.Info);
        return Task.CompletedTask;
    }

    private Task OpenExpenseDetails()
    {
        Snackbar.Add("Credit Expense — coming soon.", Severity.Info);
        return Task.CompletedTask;
    }

    private Task OpenEditExpenseModal(ExpenseDto expense)
    {
        Snackbar.Add($"Edit Expense: {expense.ExpenseName} — coming soon.", Severity.Info);
        return Task.CompletedTask;
    }

    private Task HandleDeleteExpense(Guid expenseId)
    {
        Snackbar.Add($"Delete Expense — coming soon.", Severity.Info);
        return Task.CompletedTask;
    }
    #endregion Expense
    
    public void Dispose() => HouseholdState.OnChange -= _stateChangeHandler;
}