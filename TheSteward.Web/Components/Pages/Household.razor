@page "/household"

@using System.Security.Claims
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Authorization
@using TheSteward.Shared.Components

@inject IHouseholdService HouseholdService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager
@inject IdentityRedirectManager RedirectManager

@attribute [Authorize]

<PageTitle>My Household</PageTitle>

@if (isLoading)
{
    <p><em>Loading...</em></p>
}
else if (showForm)
{
     <HouseholdForm 
        FormData="householdForm" 
        IsEditMode="isEditMode" 
        IsSubmitting="isSubmitting"
        OnSubmit="SaveHousehold"
        OnCancel="CancelEdit" />
}
else if (household != null)
{
    <HouseholdCard 
        Household="household" 
        OnEdit="EditHousehold" />
}

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger mt-3" role="alert">
        @errorMessage
    </div>
}

@code {
    private TheSteward.Core.Models.Household? household;
    private CreateUpdateHouseholdDto householdDto = new();
    private HouseholdFormDto householdForm = new();
    private bool isLoading = true;
    private bool showForm = false;
    private bool isEditMode = false;
    private bool isSubmitting = false;
    private string? errorMessage;
    private string? currentUserId;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            if (user.Identity?.IsAuthenticated == true)
            {
                currentUserId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

                if (!string.IsNullOrEmpty(currentUserId))
                {
                    var households = await HouseholdService.GetAllHouseholdsForUser(currentUserId);

                    if (households.Any())
                    {
                        household = households.First();
                    }
                    else
                    {
                        showForm = true;
                        isEditMode = false;
                    }
                }
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading household: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SaveHousehold()
    {
        if (string.IsNullOrEmpty(currentUserId))
        {
            errorMessage = "User not authenticated";
            return;
        }

        isSubmitting = true;
        errorMessage = null;

        try
        {
            if (isEditMode && household != null)
            {
                // Update existing household
                householdDto.HouseholdId = household.HouseholdId;
                householdDto.HouseholdName = householdForm.HouseholdName;
                householdDto.HasTaskManagerAccess = householdForm.HasTaskManagerAccess;
                householdDto.HasFinanceManagerAccess = householdForm.HasFinanceManagerAccess;
                householdDto.HasMealManagerAccess = householdForm.HasMealManagerAccess;
                householdDto.HasFileManagerAccess = householdForm.HasFileManagerAccess;

                await HouseholdService.UpdateAsync(householdDto);

                showForm = false;
                isEditMode = false;
            }
            else
            {
                // Create new household
                await HouseholdService.AddAsync(householdDto, currentUserId);

                // Reload to show the created household
                var households = await HouseholdService.GetAllHouseholdsForUser(currentUserId);
                household = households.FirstOrDefault();
                showForm = false;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error saving household: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void EditHousehold()
    {
        if (household == null) return;

        householdForm = new HouseholdFormDto
        {
            HouseholdName = household.HouseholdName,
            HasTaskManagerAccess = household.HasTaskManagerAccess,
            HasFinanceManagerAccess = household.HasFinanceManagerAccess,
            HasMealManagerAccess = household.HasMealManagerAccess,
            HasFileManagerAccess = household.HasFileManagerAccess
        };

        isEditMode = true;
        showForm = true;
    }

    private void CancelEdit()
    {
        showForm = false;
        isEditMode = false;
        householdForm = new HouseholdFormDto();
        errorMessage = null;
    }
}