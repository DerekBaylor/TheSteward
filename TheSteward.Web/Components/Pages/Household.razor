@page "/household"

@using System.Security.Claims
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Authorization
@inject IHouseholdService HouseholdService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager
@inject IdentityRedirectManager RedirectManager

@attribute [Authorize]

<PageTitle>My Household</PageTitle>

@if (isLoading)
{
    <p><em>Loading...</em></p>
}
else if (showForm)
{
    <h3>@(isEditMode ? "Edit Household" : "Create A Household")</h3>
    <div class="card">
        <div class="card-body">
            <h5 class="card-title">@(isEditMode ? "Update Your Household" : "Create Your Household")</h5>
            <EditForm Model="householdForm" OnValidSubmit="SaveHousehold">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="mb-3">
                    <label for="householdName" class="form-label">Household Name</label>
                    <InputText id="householdName" class="form-control" @bind-Value="householdForm.HouseholdName" />
                    <ValidationMessage For="@(() => householdForm.HouseholdName)" />
                </div>

                <div class="mb-3 form-check">
                    <InputCheckbox id="taskManager" class="form-check-input" @bind-Value="householdForm.HasTaskManagerAccess" />
                    <label class="form-check-label" for="taskManager">
                        Enable Task Manager
                    </label>
                </div>

                <div class="mb-3 form-check">
                    <InputCheckbox id="financeManager" class="form-check-input" @bind-Value="householdForm.HasFinanceManagerAccess" />
                    <label class="form-check-label" for="financeManager">
                        Enable Finance Manager
                    </label>
                </div>

                <div class="mb-3 form-check">
                    <InputCheckbox id="mealManager" class="form-check-input" @bind-Value="householdForm.HasMealManagerAccess" />
                    <label class="form-check-label" for="mealManager">
                        Enable Meal Manager
                    </label>
                </div>

                <div class="mb-3 form-check">
                    <InputCheckbox id="fileManager" class="form-check-input" @bind-Value="householdForm.HasFileManagerAccess" />
                    <label class="form-check-label" for="fileManager">
                        Enable File Manager
                    </label>
                </div>

                <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
                    @if (isSubmitting)
                    {
                        <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                    }
                    @(isEditMode ? "Update Household" : "Create Household")
                </button>

                @if (isEditMode)
                {
                    <button type="button" class="btn btn-secondary ms-2" @onclick="CancelEdit">Cancel</button>
                }
            </EditForm>
        </div>
    </div>
}
else if (household != null)
{
    <div class="card">
        <div class="card-body">
            <h5 class="card-title">@household.HouseholdName</h5>
            <p class="card-text">
                <strong>Status:</strong> @(household.IsHouseholdActive ? "Active" : "Inactive")
            </p>

            <h6 class="mt-3">Enabled Features:</h6>
            <ul class="list-unstyled">
                <li>
                    <span class="material-icons" style="@(household.HasTaskManagerAccess ? "color: green;" : "color: gray;") vertical-align: middle; font-size: 20px;">
                        @(household.HasTaskManagerAccess ? "check_circle" : "radio_button_unchecked")
                    </span>
                    <span style="@(household.HasTaskManagerAccess ? "" : "opacity: 0.6;")">Task Manager</span>
                </li>
                <li>
                    <span class="material-icons" style="@(household.HasFinanceManagerAccess ? "color: green;" : "color: gray;") vertical-align: middle; font-size: 20px;">
                        @(household.HasFinanceManagerAccess ? "check_circle" : "radio_button_unchecked")
                    </span>
                    <span style="@(household.HasFinanceManagerAccess ? "" : "opacity: 0.6;")">Finance Manager</span>
                </li>
                <li>
                    <span class="material-icons" style="@(household.HasMealManagerAccess ? "color: green;" : "color: gray;") vertical-align: middle; font-size: 20px;">
                        @(household.HasMealManagerAccess ? "check_circle" : "radio_button_unchecked")
                    </span>
                    <span style="@(household.HasMealManagerAccess ? "" : "opacity: 0.6;")">Meal Manager</span>
                </li>
                <li>
                    <span class="material-icons" style="@(household.HasFileManagerAccess ? "color: green;" : "color: gray;") vertical-align: middle; font-size: 20px;">
                        @(household.HasFileManagerAccess ? "check_circle" : "radio_button_unchecked")
                    </span>
                    <span style="@(household.HasFileManagerAccess ? "" : "opacity: 0.6;")">File Manager</span>
                </li>
            </ul>

            <button class="btn btn-secondary mt-3" @onclick="EditHousehold">Edit</button>
        </div>
    </div>
}

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger mt-3" role="alert">
        @errorMessage
    </div>
}

@code {
    private TheSteward.Core.Models.Household? household;
    private CreateUpdateHouseholdDto householdForm = new();
    private bool isLoading = true;
    private bool showForm = false;
    private bool isEditMode = false;
    private bool isSubmitting = false;
    private string? errorMessage;
    private string? currentUserId;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            if (user.Identity?.IsAuthenticated == true)
            {
                currentUserId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

                if (!string.IsNullOrEmpty(currentUserId))
                {
                    var households = await HouseholdService.GetAllHouseholdsForUser(currentUserId);

                    if (households.Any())
                    {
                        household = households.First();
                    }
                    else
                    {
                        showForm = true;
                        isEditMode = false;
                    }
                }
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading household: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SaveHousehold()
    {
        if (string.IsNullOrEmpty(currentUserId))
        {
            errorMessage = "User not authenticated";
            return;
        }

        isSubmitting = true;
        errorMessage = null;

        try
        {
            if (isEditMode && household != null)
            {
                // Update existing household
                household.HouseholdName = householdForm.HouseholdName;
                household.HasTaskManagerAccess = householdForm.HasTaskManagerAccess;
                household.HasFinanceManagerAccess = householdForm.HasFinanceManagerAccess;
                household.HasMealManagerAccess = householdForm.HasMealManagerAccess;
                household.HasFileManagerAccess = householdForm.HasFileManagerAccess;

                await HouseholdService.UpdateAsync(household);

                showForm = false;
                isEditMode = false;
            }
            else
            {
                // Create new household
                await HouseholdService.AddAsync(householdForm, currentUserId);

                // Reload to show the created household
                var households = await HouseholdService.GetAllHouseholdsForUser(currentUserId);
                household = households.FirstOrDefault();
                showForm = false;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error saving household: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void EditHousehold()
    {
        if (household == null) return;

        householdForm = new CreateUpdateHouseholdDto
        {
            HouseholdName = household.HouseholdName,
            HasTaskManagerAccess = household.HasTaskManagerAccess,
            HasFinanceManagerAccess = household.HasFinanceManagerAccess,
            HasMealManagerAccess = household.HasMealManagerAccess,
            HasFileManagerAccess = household.HasFileManagerAccess
        };

        isEditMode = true;
        showForm = true;
    }

    private void CancelEdit()
    {
        showForm = false;
        isEditMode = false;
        householdForm = new CreateUpdateHouseholdDto();
        errorMessage = null;
    }
}