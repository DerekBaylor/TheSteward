@page "/household"

@using System.ComponentModel.DataAnnotations
@using System.Security.Claims
@using AutoMapper
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using TheSteward.Core.Dtos.HouseholdDtos
@using TheSteward.Core.Dtos.UserDtos
@using TheSteward.Infrastructure.Services
@using TheSteward.Shared.Components
@using TheSteward.Shared.Components.HouseholdComponents

@inject IHouseholdService HouseholdService
@inject IUserHouseholdService UserHouseholdService
@inject IUserService UserService
@inject HouseholdState HouseholdState
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager
@inject IdentityRedirectManager RedirectManager

@attribute [Authorize]

<PageTitle>My Household</PageTitle>

@if (isLoading)
{
    <p><em>Loading...</em></p>
}
else
{
    <div id="householdToolContainer" class="household-tool-container">
    @if (selectedHouseholdDto != null)
        {            
            <div class="ts-select-group">
                <label for="householdSelect" class="ts-select-label">Active Household: </label>

                <TsSelect TValue="Guid?"
                          Items="householdItems"
                          @bind-Value="selectedHouseholdId"
                          OnChange="OnHouseholdChanged"
                          Placeholder="Choose household" />
            </div>
        }

        <button class="ts-btn ts-submit-btn" @onclick="OpenHouseholdForm">Add Household</button>
        <button class="ts-btn ts-edit-btn" @onclick="ShowUserProfile">My Profile</button>
    </div>

    @if (!hasDefaultHousehold)
    {
        <MudAlert id="householdAlert" Severity="Severity.Warning" role="alert">
            You are not part of a household. Please Add a household, or accept an invitation.         
            <button class="ts-btn ts-submit-btn" @onclick="OpenHouseholdForm">Add Household</button>
        </MudAlert>
    }

    @if (pendingInvitations.Any())
    {
        <PendingInvitations Invitations="pendingInvitations"
                            HasExistingHousehold="hasDefaultHousehold"
                            OnAccept="AcceptInvitation"
                            OnDecline="DeclineInvitation"
                            OnHide="HideInvitation" />
    }

    @if (showHouseholdForm)
    {
        <div class="household-form-container">
            <HouseholdForm 
                IsEditMode="isEditHouseholdMode"
                FormData="householdFormDto"
                HasDefaultHousehold="hasDefaultHousehold"
                IsSubmitting="isSubmitting"
                OnSubmit="SaveHousehold"
                OnCancel="CancelHouseholdEdit" />
        </div>

    }
    else if (showHouseholdCard && selectedHouseholdDto != null)
    {
        <div class="household-container"> 
            <div class="household-card-container">
                <h4 class="section-title"> Household Information </h4>

                <HouseholdCard HouseholdDto="selectedHouseholdDto"
                    HasAdminPermissions="hasAdminPermissions"
                    OnEditHosuehold="EditHousehold"
                    OnAddMember="AddMember"
                    GetMember="GetMember" />
    
            </div>

            <div class="userHousehold-container">
                <div class="household-card-container">
                    @if (showMemberPermissionsForm && userHouseholdFormDto != null)
                    {
                        <h4 class="section-title"> Member Permissions</h4>
                        <UserHouseholdForm 
                            FormData="userHouseholdFormDto"
                            IsSubmitting="isSubmitting"
                            OnSubmit="SaveUserHousehold"
                            OnCancel="CancelUserHouseholdEdit" />

                    }
                    else if (selectedUserHouseholdDto != null && showMemberCard)
                        {

                        <h4 class="section-title"> Member Information</h4>
                        <UserHouseholdCard 
                            UserHouseholdDto="selectedUserHouseholdDto"
                            OnCancel="ClearSelectedMember"
                            OnEdit="() => EditMemberPermissions(selectedUserHouseholdDto)" />
                    }
                </div>
            </div>
        </div>
    }

    @if (showUserProfileForm && userProfileFormDto != null)
    {
        <div class="household-form-container mt-3">
            <h4 class="section-title">Edit My Profile</h4>
            <UserProfileForm FormData="userProfileFormDto"
                                IsSubmitting="isSubmitting"
                                OnSubmit="SaveUserProfile"
                                OnCancel="CancelUserProfileEdit" />
        </div>
    }
    else if (showUserProfileCard && currentUser != null)
    {
        <div class="household-container mt-3">
            <div class="household-card-container">
                <h4 class="section-title">My Profile</h4>
                <UserProfileCard User="currentUser"
                                    OnClose="CloseUserProfile"
                                    OnEdit="EditUserProfile" />
            </div>
        </div>
    }
}

@if (showInviteModal && selectedHouseholdDto != null)
{
    <InviteMemberModal HouseholdId="selectedHouseholdDto.HouseholdId"
                       OnClose="CloseInviteModal"
                       OnInviteSent="SendInvitation" />
}

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger mt-3" role="alert">
        @errorMessage
    </div>
}


@code {
    private List<HouseholdDto> households = new();
    private Guid? selectedHouseholdId { get; set; }
    private CreateHouseholdDto createHouseholdDto = new();
    private UpdateHouseholdDto updateHouseholdDto = new();
    private HouseholdFormDto householdFormDto = new();
    private HouseholdDto? selectedHouseholdDto = null;
    private List<SelectItem<Guid?>> householdItems = new();

    private UserHouseholdDto? userHouseholdDto = null;
    private UserHouseholdDto? selectedUserHouseholdDto = null;
    private UserHouseholdFormDto? userHouseholdFormDto = null;
    private ApplicationUser? selectedMember;

    private List<HouseholdInvitationDto> pendingInvitations = new();

    private UserProfileFormDto? userProfileFormDto = null;
    private ApplicationUser? currentUser = null;

    private bool isLoading = true;
    private bool isLoadingMember = false;
    private bool showHouseholdForm = false;
    private bool showHouseholdCard = false;
    private bool isEditHouseholdMode = false;
    private bool isEditUserHouseholdMode = false;
    private bool isSubmitting = false;
    private bool hasDefaultHousehold = false;
    private bool hasAdminPermissions = false;
    private bool showMemberPermissionsForm = false;
    private bool showMemberCard = false;
    private bool showInviteModal = false;
    private bool showUserProfileForm = false;
    private bool showUserProfileCard = false;

    private string? errorMessage;
    private string? currentUserId;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            var email = user.FindFirst(ClaimTypes.Email)?.Value;
            if (!string.IsNullOrEmpty(email))
            {
                pendingInvitations = await UserHouseholdService.GetPendingInvitationsForUserAsync(email);
            }

            if (user.Identity?.IsAuthenticated != true)
            {
                NavigationManager.NavigateTo("/login", true);
                return;
            }

            currentUserId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            if (string.IsNullOrEmpty(currentUserId))
                return;

            currentUser = await UserService.GetUserByIdAsync(currentUserId);

            var currentHouseholdDto = HouseholdState.CurrentHousehold;

            if (currentHouseholdDto != null)
            {
                await GetUserHouseholdAndPermissions(currentHouseholdDto.HouseholdId);
                households = await UserHouseholdService.GetAllHouseholdsForUserAsync(currentUserId);
                PopulateHouseholdItems();
                selectedHouseholdId = currentHouseholdDto.HouseholdId;
            }
            else
            {
                // If state is not set for some reason, fall back to default household
                var defaultUserHousehold = await UserHouseholdService
                    .GetDefaultUserHouseholdForUserAsync(currentUserId);

                if (defaultUserHousehold?.Household != null)
                {               
                    await GetUserHouseholdAndPermissions(defaultUserHousehold.Household.HouseholdId);
                    households = await UserHouseholdService.GetAllHouseholdsForUserAsync(currentUserId);
                    PopulateHouseholdItems();
                    selectedHouseholdId = defaultUserHousehold.Household.HouseholdId;

                    HouseholdState.SetHousehold(defaultUserHousehold.Household);
                }
                else
                {
                    // No household exists, household show add household form
                    hasDefaultHousehold = false;
                    showHouseholdCard = false;
                    showHouseholdForm = true;
                    isLoading = false;

                    return;
                }
            }

            hasDefaultHousehold = true;
            showHouseholdCard = true;

        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading household: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    #region Household Management
    private void PopulateHouseholdItems()
    {
        householdItems = households.Select(h => new SelectItem<Guid?>
        {
            Value = h.HouseholdId,
            Text = h.HouseholdName
        }).ToList();
    }

    private async Task OnHouseholdChanged()
    {
        selectedHouseholdDto = households?.FirstOrDefault(h => h.HouseholdId == selectedHouseholdId);

        if (selectedHouseholdDto != null)
        {
            await GetUserHouseholdAndPermissions(selectedHouseholdDto.HouseholdId);

            HouseholdState.SetHousehold(selectedHouseholdDto);

            StateHasChanged();
        }
    }

    private async Task GetUserHouseholdAndPermissions(Guid householdId)
    {
        try
        {
            selectedHouseholdId = householdId;

            if (string.IsNullOrEmpty(currentUserId))
            {
                errorMessage = "User ID not found";
                selectedUserHouseholdDto = null;
                selectedHouseholdDto = null;
                hasAdminPermissions = false;

                return;
            }

            selectedUserHouseholdDto = await UserHouseholdService
                .GetUserHouseholdByHouseholdIdAndUserIdAsync(householdId, currentUserId);

            if (selectedUserHouseholdDto?.Household != null)
            {
                selectedHouseholdDto = selectedUserHouseholdDto.Household;
                hasAdminPermissions = selectedUserHouseholdDto.HasAdminPermissions;
            }
            else
            {
                errorMessage = "Could not load household data";
                selectedHouseholdDto = null;
                hasAdminPermissions = false;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error getting household: {ex.Message}";
            selectedHouseholdDto = null;
            hasAdminPermissions = false;
        }
    }

    private void OpenHouseholdForm()
    {
        showHouseholdForm = true;
    }

    private async Task SaveHousehold()
    {
        if (string.IsNullOrEmpty(currentUserId))
        {
            errorMessage = "User not authenticated";
            return;
        }

        isSubmitting = true;
        errorMessage = null;

        try
        {
            if (isEditHouseholdMode && selectedHouseholdDto != null) // Update household
            {
                updateHouseholdDto.HouseholdId = selectedHouseholdDto.HouseholdId;
                updateHouseholdDto.IsDefaultHousehold = hasDefaultHousehold;
                updateHouseholdDto.HouseholdName = householdFormDto.HouseholdName;
                updateHouseholdDto.HasTaskManagerAccess = householdFormDto.HasTaskManagerAccess;
                updateHouseholdDto.HasFinanceManagerAccess = householdFormDto.HasFinanceManagerAccess;
                updateHouseholdDto.HasMealManagerAccess = householdFormDto.HasMealManagerAccess;
                updateHouseholdDto.HasFileManagerAccess = householdFormDto.HasFileManagerAccess;

                await HouseholdService.UpdateAsync(updateHouseholdDto);

                households = await UserHouseholdService.GetAllHouseholdsForUserAsync(currentUserId);
                PopulateHouseholdItems();

                await GetUserHouseholdAndPermissions(selectedHouseholdDto.HouseholdId);
            }
            else // Create household
            {
                createHouseholdDto.IsDefaultHousehold = !hasDefaultHousehold;
                createHouseholdDto.HouseholdName = householdFormDto.HouseholdName;
                createHouseholdDto.HasTaskManagerAccess = householdFormDto.HasTaskManagerAccess;
                createHouseholdDto.HasFinanceManagerAccess = householdFormDto.HasFinanceManagerAccess;
                createHouseholdDto.HasMealManagerAccess = householdFormDto.HasMealManagerAccess;
                createHouseholdDto.HasFileManagerAccess = householdFormDto.HasFileManagerAccess;

                await HouseholdService.AddAsync(createHouseholdDto, currentUserId);

                var defaultUserHousehold = await UserHouseholdService.GetDefaultUserHouseholdForUserAsync(currentUserId);

                if (defaultUserHousehold?.Household != null)
                {
                    households = await UserHouseholdService.GetAllHouseholdsForUserAsync(currentUserId);
                    PopulateHouseholdItems();

                    await GetUserHouseholdAndPermissions(defaultUserHousehold.Household.HouseholdId);

                    hasDefaultHousehold = true;
                    HouseholdState.SetHousehold(defaultUserHousehold.Household);
                }
                else
                {
                    errorMessage = "Unable to load household after save";
                }
            }

            showHouseholdForm = false;
            showHouseholdCard = true;
            isEditHouseholdMode = false;

            StateHasChanged();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error saving household: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void EditHousehold()
    {
        if (selectedHouseholdDto == null) return;

        householdFormDto = new HouseholdFormDto
        {
            HouseholdName = selectedHouseholdDto.HouseholdName,
            HasTaskManagerAccess = selectedHouseholdDto.HasTaskManagerAccess,
            HasFinanceManagerAccess = selectedHouseholdDto.HasFinanceManagerAccess,
            HasMealManagerAccess = selectedHouseholdDto.HasMealManagerAccess,
            HasFileManagerAccess = selectedHouseholdDto.HasFileManagerAccess
        };

        isEditHouseholdMode = true;
        showHouseholdForm = true;
        showHouseholdCard = false;
    }

    private void CancelHouseholdEdit()
    {
        showHouseholdForm = false;
        showHouseholdCard = true;
        isEditHouseholdMode = false;
        householdFormDto = new HouseholdFormDto();
        errorMessage = null;
    }

    #endregion Household Management

    #region User Profile Management
    private void EditUserProfile()
    {
        if (currentUser == null)
        {
            errorMessage = "User profile not loaded.";
            return;
        }

        userProfileFormDto = new UserProfileFormDto
        {
            UserName = currentUser.UserName ?? "",
            Email = currentUser.Email ?? "",
            PhoneNumber = currentUser.PhoneNumber
        };

        showUserProfileForm = true;
        showUserProfileCard = false;
    }

    private void CancelUserProfileEdit()
    {
        showUserProfileForm = false;
        showUserProfileCard = false;
        userProfileFormDto = null;
        errorMessage = null;
    }

    private async Task SaveUserProfile()
    {
        if (string.IsNullOrEmpty(currentUserId) || userProfileFormDto == null || currentUser == null)
        {
            errorMessage = "Invalid data for saving profile";
            return;
        }

        isSubmitting = true;
        errorMessage = null;

        try
        {
            var updateDto = new UpdateUserProfileDto
            {
                UserId = currentUserId,
                UserName = userProfileFormDto.UserName,
                Email = userProfileFormDto.Email,
                PhoneNumber = userProfileFormDto.PhoneNumber
            };

            var result = await UserService.UpdateUserProfileAsync(updateDto);

            if (result.Succeeded)
            {
                currentUser = await UserService.GetUserByIdAsync(currentUserId);

                showUserProfileForm = false;
                showUserProfileCard = false;

                NavigationManager.NavigateTo("/household", forceLoad: true);
            }
            else
            {
                errorMessage = string.Join(", ", result.Errors.Select(e => e.Description));
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error saving profile: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void ShowUserProfile()
    {
        if (currentUser == null)
        {
            errorMessage = "User profile not loaded.";
            return;
        }

        showUserProfileCard = true;
    }
    private void CloseUserProfile()
    {
        showUserProfileCard = false;
    }

    #endregion User Profile Management

    #region Member Invitation

    private void AddMember()
    {
        if (selectedHouseholdDto == null)
        {
            errorMessage = "Household data not loaded.";
            return;
        }

        showInviteModal = true;
    }

    private void CloseInviteModal()
    {
        showInviteModal = false;
    }

    private async Task SendInvitation(InviteUserToHouseholdDto inviteDto)
    {
        if (string.IsNullOrEmpty(currentUserId))
        {
            errorMessage = "User not authenticated.";
            return;
        }

        try
        {
            await UserHouseholdService.InviteUserToHouseholdAsync(inviteDto, currentUserId);
            errorMessage = null;
        }
        catch (Exception ex)
        {
            errorMessage = $"Error sending invitation: {ex.Message}";
            throw;
        }
    }

    private async Task AcceptInvitation((Guid InvitationId, bool SetAsDefault) data)
    {
        if (string.IsNullOrEmpty(currentUserId))
        {
            errorMessage = "User not authenticated.";
            return;
        }

        try
        {
            await UserHouseholdService.AcceptInvitationAsync(data.InvitationId, currentUserId, data.SetAsDefault);

            NavigationManager.NavigateTo("/household", forceLoad: true);
        }
        catch (Exception ex)
        {
            errorMessage = $"Error accepting invitation: {ex.Message}";
        }
    }

    private async Task DeclineInvitation(Guid invitationId)
    {
        if (string.IsNullOrEmpty(currentUserId))
        {
            errorMessage = "User not authenticated.";
            return;
        }

        try
        {
            await UserHouseholdService.CancelInvitationAsync(invitationId, currentUserId);

            var email = (await AuthenticationStateProvider.GetAuthenticationStateAsync())
                .User.FindFirst(ClaimTypes.Email)?.Value;
            if (!string.IsNullOrEmpty(email))
            {
                pendingInvitations = await UserHouseholdService.GetPendingInvitationsForUserAsync(email);
            }

            errorMessage = null;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error declining invitation: {ex.Message}";
        }
    }

    private void HideInvitation()
    {
        StateHasChanged();
    }
    #endregion Member Invitation


    private async Task GetMember(ApplicationUser member)
    {
        if (selectedHouseholdDto == null)
        {
            errorMessage = "Household data not loaded.";
            return;
        }

        isLoadingMember = true;
        errorMessage = null;
        selectedUserHouseholdDto = null;
        StateHasChanged();

        try
        {
            var userHousehold = await UserHouseholdService.GetUserHouseholdByHouseholdIdAndUserIdAsync(selectedHouseholdDto.HouseholdId, member.Id);

            if (userHousehold != null)
            {
                selectedUserHouseholdDto = userHousehold;
                selectedMember = member;
            }
            else
            {
                errorMessage = "Unable to load member details.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading member details: {ex.Message}";
        }
        finally
        {
            isLoadingMember = false;
            showMemberCard = true;
            StateHasChanged();
        }
    }

    private void ClearSelectedMember()
    {
        selectedUserHouseholdDto = null;
        showMemberCard = false;
        selectedMember = null;
        errorMessage = null;
    }

    private void EditMemberPermissions(UserHouseholdDto userHouseholdDto)
    {
        if (userHouseholdDto == null)
        {
            errorMessage = "User household data is missing.";
            return;
        }

        userHouseholdFormDto = new UserHouseholdFormDto
        {
            UserHouseholdId = userHouseholdDto.UserHouseholdId,
            MemberName = userHouseholdDto.User?.UserName ?? "Unknown",
            IsHouseholdOwner = userHouseholdDto.IsHouseholdOwner,
            HasAdminPermissions = userHouseholdDto.HasAdminPermissions,
            HasFinanceManagerReadPermission = userHouseholdDto.HasFinanceManagerReadPermission,
            HasFinanceManagerWritePermission = userHouseholdDto.HasFinanceManagerWritePermission,
            HasKitchenManagerReadPermission = userHouseholdDto.HasKitchenManagerReadPermission,
            HasKitchenManagerWritePermission = userHouseholdDto.HasKitchenManagerWritePermission,
            HasTaskManagerReadPermission = userHouseholdDto.HasTaskManagerReadPermission,
            HasTaskManagerWritePermission = userHouseholdDto.HasTaskManagerWritePermission,
            HasFileManagerReadPermission = userHouseholdDto.HasFileManagerReadPermission,
            HasFileManagerWritePermission = userHouseholdDto.HasFileManagerWritePermission
        };

        showMemberPermissionsForm = true;
    }

    private void CancelUserHouseholdEdit()
    {
        showMemberPermissionsForm = false;
        isEditUserHouseholdMode = false;
        userHouseholdFormDto = null;
        errorMessage = null;
    }

    private async Task SaveUserHousehold()
    {
        if (string.IsNullOrEmpty(currentUserId) || userHouseholdFormDto == null)
        {
            errorMessage = "Invalid data for saving permissions";
            return;
        }

        if (selectedUserHouseholdDto == null)
        {
            errorMessage = "No member selected for updating permissions";
            return;
        }

        isSubmitting = true;
        errorMessage = null;

        try
        {
            var updateUserHouseholdDto = new UpdateUserHouseholdDto
            {
                UserId = selectedUserHouseholdDto.UserId,
                UserHouseholdId = userHouseholdFormDto.UserHouseholdId,
                IsHouseholdOwner = userHouseholdFormDto.IsHouseholdOwner,
                HouseholdId = selectedUserHouseholdDto.HouseholdId,
                IsDefaultUserHousehold = selectedUserHouseholdDto.IsDefaultUserHousehold,
                HasAdminPermissions = userHouseholdFormDto.HasAdminPermissions,
                HasFinanceManagerWritePermission = userHouseholdFormDto.HasFinanceManagerWritePermission,
                HasFinanceManagerReadPermission = userHouseholdFormDto.HasFinanceManagerReadPermission,
                HasKitchenManagerWritePermission = userHouseholdFormDto.HasKitchenManagerWritePermission,
                HasKitchenManagerReadPermission = userHouseholdFormDto.HasKitchenManagerReadPermission,
                HasTaskManagerWritePermission = userHouseholdFormDto.HasTaskManagerWritePermission,
                HasTaskManagerReadPermission = userHouseholdFormDto.HasTaskManagerReadPermission,
                HasFileManagerWritePermission = userHouseholdFormDto.HasFileManagerWritePermission,
                HasFileManagerReadPermission = userHouseholdFormDto.HasFileManagerReadPermission
            };

            await UserHouseholdService.UpdateAsync(updateUserHouseholdDto);

            if (selectedHouseholdDto != null && selectedMember != null)
            {
                var updatedUserHousehold = await UserHouseholdService.GetUserHouseholdByHouseholdIdAndUserIdAsync(
                    selectedHouseholdDto.HouseholdId,
                    selectedMember.Id);

                if (updatedUserHousehold != null)
                {
                    selectedUserHouseholdDto = updatedUserHousehold;
                }
            }

            showMemberPermissionsForm = false;
            isEditUserHouseholdMode = false;

            StateHasChanged();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error saving member permissions: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }
}