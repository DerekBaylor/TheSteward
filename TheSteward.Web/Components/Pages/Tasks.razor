@page "/tasks"

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using TheSteward.Core.Dtos.TaskManagerDtos
@using TheSteward.Core.IServices.TaskManagerIServices
@using TheSteward.Shared.Components.TaskManagerComponents
@using TheSteward.Shared.Dtos.HouseholdDtos
@using TheSteward.Shared.Dtos.TaskDtos
@using static TheSteward.Core.Utils.TaskManagerUtils.TaskManagerConstants

@inject AuthenticationStateProvider AuthenticationStateProvider
@inject HouseholdState HouseholdState
@inject ITaskItemService TaskItemService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

@attribute [Authorize]
@implements IDisposable

<PageTitle>Task Manager</PageTitle>

<TaskManagerToolBar OnHouseholdChanged="OnHouseholdChanged" />

@if (HouseholdState.CurrentUserHousehold == null)
{
    <MudAlert Severity="Severity.Warning" Class="mt-4">
        You are not part of a household. Please visit the
        <MudLink Href="/household">Household page</MudLink> to get started.
    </MudAlert>
}
else if (!HouseholdState.HasTaskManagerReadPermission)
{
    <MudAlert Severity="Severity.Error" Class="mt-4">
        You do not have permission to view tasks for this household.
        Please contact your household admin.
    </MudAlert>
}
else if (isLoading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mt-4" />
}
else
{
    <div class="tm-container">
        <div class="tm-body">

            @* ── Filter Strip ── *@
            <div class="tm-filter-strip">

                @* Status Chips *@
                <div class="tm-filter-group">

                    <div class="tm-top-filter-row">
                        @if (HouseholdState.HasTaskManagerWritePermission)
                        {
                            <button class="budget-action-btn budget-action-btn--add"
                                    @onclick="OpenAddTaskModal">
                                <span class="material-symbols-outlined">add</span>
                                Add Task
                            </button>
                        }
                    </div>

                    <div class="tm-bottom-filter-row">

                        <div class="tm-bottom-filter-row">

                            <button class="tm-stat-chip @(activeStatusFilter == null && activePriorityFilter == null ? "active" : "")"
                                    @onclick="ClearFilters">
                                <span class="material-symbols-outlined">list</span>
                                All
                                <span class="tm-chip-count">@tasks.Count</span>
                            </button>

                            @foreach (var status in Enum.GetValues<TaskItemStatus>())
                            {
                                <button class="tm-stat-chip tm-stat-chip--@status.ToString().ToLower() @(activeStatusFilter == status ? "active" : "")"
                                        @onclick="() => SetStatusFilter(status)">
                                    <span class="material-symbols-outlined">@GetStatusIcon(status)</span>
                                    @status
                                    <span class="tm-chip-count">@tasks.Count(t => t.Status == status)</span>
                                </button>
                            }

                            <button class="tm-stat-chip tm-stat-chip--urgent @(activePriorityFilter == TaskItemPriority.Urgent ? "active" : "")"
                                    @onclick="OnUrgentChipClicked">
                                <span class="material-symbols-outlined">priority_high</span>
                                Urgent
                                <span class="tm-chip-count">@tasks.Count(t => t.Priority == TaskItemPriority.Urgent)</span>
                            </button>

                            @foreach (var priority in Enum.GetValues<TaskItemPriority>())
                            {
                                <button class="tm-priority-chip tm-priority-chip--@priority.ToString().ToLower() @(activePriorityFilter == priority ? "active" : "")"
                                        @onclick="() => SetPriorityFilter(priority)">
                                    <span class="material-symbols-outlined">flag</span>
                                    @priority
                                </button>
                            }

                        </div>
                    </div>
                </div>
            </div>




            @* ── Task List ── *@
            <div class="tm-task-list">
                @if (!FilteredTasks.Any())
                {
                    <div class="tm-empty-state">
                        <span class="material-symbols-outlined tm-empty-icon">checklist</span>
                        <p class="tm-empty-title">No tasks found</p>
                        <p class="tm-empty-subtitle">Try adjusting your filters or add a new task.</p>
                    </div>
                }
                else
                {
                    @foreach (var task in FilteredTasks)
                    {
                        <div class="tm-task-card">
                            <div class="tm-task-card-left">
                                <span class="tm-priority-indicator tm-priority-indicator--@task.Priority.ToString().ToLower()"></span>
                                <div class="tm-task-info">
                                    <p class="tm-task-name">@task.TaskItemName</p>
                                    @if (!string.IsNullOrEmpty(task.Description))
                                    {
                                        <p class="tm-task-description">@task.Description</p>
                                    }
                                    <div class="tm-task-meta">
                                        <span class="tm-task-category">
                                            <span class="material-symbols-outlined">label</span>
                                            @task.TaskItemCategoryName
                                        </span>
                                        @if (task.DueDate.HasValue)
                                        {
                                            <span class="tm-task-due @(task.DueDate < DateTime.UtcNow && task.Status != TaskItemStatus.Completed ? "overdue" : "")">
                                                <span class="material-symbols-outlined">event</span>
                                                @task.DueDate.Value.ToString("MMM dd, yyyy")
                                            </span>
                                        }
                                        @if (task.ExpenseId.HasValue)
                                        {
                                            <span class="tm-task-linked-expense">
                                                <span class="material-symbols-outlined">link</span>
                                                @task.RelatedExpenseName
                                            </span>
                                        }
                                    </div>
                                </div>
                            </div>
                            <div class="tm-task-card-right">
                                <span class="tm-status-badge tm-status-badge--@task.Status.ToString().ToLower()">
                                    @task.Status
                                </span>
                                <div class="tm-task-actions">
                                    <button class="ts-btn ts-edit-btn"
                                            @onclick="() => OpenEditTaskModal(task)">
                                        <span class="material-symbols-outlined">edit</span>
                                    </button>
                                    @if (task.Status != TaskItemStatus.Completed)
                                    {
                                        <button class="ts-btn ts-submit-btn"
                                                @onclick="() => HandleCompleteTask(task)">
                                            <span class="material-symbols-outlined">check</span>
                                        </button>
                                    }
                                    <button class="ts-btn ts-cancel-btn"
                                            @onclick="() => HandleDeleteTask(task.TaskItemId)">
                                        <span class="material-symbols-outlined">delete</span>
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
}

@if (!string.IsNullOrEmpty(errorMessage))
{
    <MudAlert Severity="Severity.Error" Class="mt-3">@errorMessage</MudAlert>
}

@code {
    private bool isLoading = true;
    private string? errorMessage;
    private TaskItemStatus? activeStatusFilter;
    private TaskItemPriority? activePriorityFilter;
    private List<TaskItemDto> tasks = new();
    private Action? _stateChangeHandler;

    private IEnumerable<TaskItemDto> FilteredTasks => tasks
        .Where(t => activeStatusFilter == null || t.Status == activeStatusFilter)
        .Where(t => activePriorityFilter == null || t.Priority == activePriorityFilter)
        .OrderBy(t => t.DueDate);

    protected override async Task OnInitializedAsync()
    {
        _stateChangeHandler = () => InvokeAsync(StateHasChanged);
        HouseholdState.OnChange += _stateChangeHandler;
        await LoadTasksAsync();
    }

    public void Dispose() => HouseholdState.OnChange -= _stateChangeHandler;

    private async Task LoadTasksAsync()
    {
        var userHousehold = HouseholdState.CurrentUserHousehold;

        if (userHousehold == null || !HouseholdState.HasTaskManagerReadPermission)
        {
            isLoading = false;
            return;
        }

        try
        {
            isLoading = true;
            tasks = await TaskItemService.GetAllByAssignedUserHouseholdIdAsync(
                userHousehold.UserHouseholdId);
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading tasks: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task RefreshTasksAsync()
    {
        var userHousehold = HouseholdState.CurrentUserHousehold;
        if (userHousehold == null) return;

        tasks = await TaskItemService.GetAllByAssignedUserHouseholdIdAsync(
            userHousehold.UserHouseholdId);

        StateHasChanged();
    }

    #region Household

    private async void OnHouseholdChanged(UserHouseholdDto _)
    {
        tasks.Clear();
        errorMessage = null;
        await LoadTasksAsync();
        StateHasChanged();
    }

    #endregion Household

    #region Filters

    private void ClearFilters()
    {
        activeStatusFilter = null;
        activePriorityFilter = null;
    }

    private void SetStatusFilter(TaskItemStatus status)
    {
        activePriorityFilter = null;
        activeStatusFilter = activeStatusFilter == status ? null : status;
    }

    private void SetPriorityFilter(TaskItemPriority? priority)
    {
        activePriorityFilter = activePriorityFilter == priority ? null : priority;
    }

    private void OnUrgentChipClicked()
    {
        if (activePriorityFilter == TaskItemPriority.Urgent)
        {
            activePriorityFilter = null;
        }
        else
        {
            activeStatusFilter = null;
            activePriorityFilter = TaskItemPriority.Urgent;
        }
    }

    private static string GetStatusIcon(TaskItemStatus status) => status switch
    {
        TaskItemStatus.Pending => "pending",
        TaskItemStatus.InProgress => "autorenew",
        TaskItemStatus.Completed => "check_circle",
        TaskItemStatus.Skipped => "skip_next",
        _ => "circle"
    };

    #endregion Filters

    private async Task OpenAddTaskModal()
    {
        var userHousehold = HouseholdState.CurrentUserHousehold!;

        var formData = new TaskItemFormDto
        {
            CreatedByUserHouseholdId = userHousehold.UserHouseholdId,
            AssignedToUserHouseholdId = userHousehold.UserHouseholdId,
            Status = TaskItemStatus.Pending,
            Priority = TaskItemPriority.Medium,
            IsEditMode = false
        };

        await OpenTaskModal(formData);
    }

    private async Task OpenEditTaskModal(TaskItemDto task)
    {
        var formData = new TaskItemFormDto
        {
            TaskItemId = task.TaskItemId,
            TaskItemName = task.TaskItemName,
            Description = task.Description,
            Status = task.Status,
            Priority = task.Priority,
            DueDate = task.DueDate,
            CreatedByUserHouseholdId = task.CreatedByUserHouseholdId,
            AssignedToUserHouseholdId = task.AssignedToUserHouseholdId,
            TaskItemCategoryId = task.TaskItemCategoryId,
            RecurrenceId = task.RecurrenceId,
            ExpenseId = task.ExpenseId,
            IsEditMode = true
        };

        await OpenTaskModal(formData);
    }

    private async Task OpenTaskModal(TaskItemFormDto formData)
    {
        var parameters = new DialogParameters
        {
            { "FormData", formData }
        };

        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<TaskItemModal>(
            formData.IsEditMode ? "Edit Task" : "Add Task",
            parameters,
            options);

        var result = await dialog.Result;

        if (result.Canceled) return;

        if (result.Data is string resultData && resultData.StartsWith("delete:"))
        {
            var idString = resultData["delete:".Length..];
            if (Guid.TryParse(idString, out var taskId))
                await HandleDeleteTask(taskId);
            return;
        }

        await RefreshTasksAsync();
    }

    private async Task HandleCompleteTask(TaskItemDto task)
    {
        try
        {
            await TaskItemService.CompleteAsync(
                task.TaskItemId,
                HouseholdState.CurrentUserHousehold!.UserHouseholdId);

            Snackbar.Add("Task marked as complete!", Severity.Success);
            await RefreshTasksAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error completing task: {ex.Message}", Severity.Error);
        }
    }

    private async Task HandleDeleteTask(Guid taskItemId)
    {
        try
        {
            await TaskItemService.DeleteAsync(taskItemId);
            Snackbar.Add("Task deleted.", Severity.Success);
            await RefreshTasksAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error deleting task: {ex.Message}", Severity.Error);
        }
    }
}